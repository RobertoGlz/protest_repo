  4. }
    num_protests_MM: 99 zero-imputed
    num_violent_MM: 145 zero-imputed
    num_peaceful_MM: 110 zero-imputed
    government_response_violent: 168 zero-imputed

. 
. foreach outcome of local outcome_list {
  2. 
.         if "`outcome'" == "num_protests_MM"             local ytitle "protest
> s (any)"
  3.         if "`outcome'" == "num_violent_MM"              local ytitle "viol
> ent protests"
  4.         if "`outcome'" == "num_peaceful_MM"             local ytitle "peac
> eful protests"
  5.         if "`outcome'" == "government_response_violent" local ytitle "gvt.
>  violent response"
  6. 
.         display in yellow "=== Per-scandal `outcome': President vs Others (ze
> ro-imputed) ==="
  7.         tabstat b_`outcome', by(presi) ///
>                 statistics(n mean p50 sd min max) columns(statistics)
  8. 
.         quietly levelsof presi, local(__cats)
  9.         local med_note `""'
 10.         foreach c of local __cats {
 11.                 quietly summarize b_`outcome' if presi == `c', detail
 12.                 local __mstr = string(r(p50), "%5.3f")
 13.                 quietly count if !missing(b_`outcome') & presi == `c'
 14.                 local __nstr = r(N)
 15.                 local __lbl : label PRESI `c'
 16.                 local med_note `"`med_note' "Median `__lbl' = `__mstr'    
>  (Scandals = `__nstr')""'
 17.         }
 18. 
.         graph box b_`outcome', over(presi, label(labsize(large))) ///
>                 nooutsides ///
>                 ytitle("Per-scandal effect on `ytitle'", size(medlarge)) ///
>                 ylabel(, format(%4.2f) angle(0) labsize(large)) ///
>                 yline(0, lpattern(dash) lcolor(gs8)) ///
>                 note(`med_note', size(medlarge)) ///
>                 medtype(line) ///
>                 box(1, lcolor(black) lwidth(thick)) ///
>                 box(2, lcolor(black) lwidth(thick)) ///
>                 scheme(s2color) graphregion(color(white))
 19.         graph export ///
>                 "${figout}/per_scandal_box_`outcome'_w`window_length'_presi_z
> ero.pdf", replace
 20. 
.         preserve
 21.                 keep if !missing(b_`outcome') & !missing(presi) & !missing
> (se_`outcome')
 22.                 generate double prec = 1 / se_`outcome'^2
 23.                 quietly summarize prec
 24.                 replace prec = prec / r(max)
 25. 
.                 quietly levelsof presi, local(cats)
 26.                 gen double cmean = .
 27.                 gen double clo   = .
 28.                 gen double chi   = .
 29.                 foreach c of local cats {
 30.                         quietly count if presi == `c'
 31.                         if r(N) >= 2 {
 32.                                 quietly mean b_`outcome' if presi == `c'
 33.                                 matrix mb = r(table)
 34.                                 quietly replace cmean = mb[1,1] if presi =
> = `c'
 35.                                 quietly replace clo   = mb[5,1] if presi =
> = `c'
 36.                                 quietly replace chi   = mb[6,1] if presi =
> = `c'
 37.                         }
 38.                 }
 39. 
.                 twoway ///
>                         (scatter b_`outcome' presi [aw=prec], ///
>                                 jitter(8) mcolor(navy%35) msymbol(O)) ///
>                         (rcap clo chi presi, lcolor(black) lwidth(medthick)) 
> ///
>                         (scatter cmean presi, mcolor(black) msymbol(D) msize(
> medlarge)), ///
>                         yline(0, lpattern(dash) lcolor(gs8)) ///
>                         ytitle("Per-scandal effect on `ytitle'") ///
>                         xtitle("Type of official involved") ///
>                         xlabel(1 "President" 2 "Others", noticks) ///
>                         xscale(range(0.5 2.5)) ///
>                         ylabel(, format(%4.2f) angle(0)) ///
>                         legend(order(3 "Category mean" 2 "95% CI" 1 "Per-scan
> dal b") ///
>                                 pos(1) ring(0) region(lcolor(gs10)) size(smal
> l) cols(1)) ///
>                         note("Each point is one scandal; marker size proporti
> onal to 1/SE^2." ///
>                                 "Narrow +-`window_length'-day window; zero-va
> riation scandals excluded from jitter.") ///
>                         scheme(s2color) graphregion(color(white))
 40.                 graph export ///
>                         "${figout}/per_scandal_jitter_`outcome'_w`window_leng
> th'_presi_zero.pdf", replace
 41.         restore
 42. }
