. do per_scandal_effects_presi_vs_others_zero.do 

. /* --------------------------------------------------------------------------
> --
>                         Violent effects of apex corruption
>         Per-scandal box / jitter plots: President vs Others,
>         ZERO-IMPUTED variant.
> 
>     Code author: Roberto Gonzalez
>     Date: 2026-06-28
> 
>     Difference from per_scandal_effects_presi_vs_others.do:
>         Scandals whose outcome has zero within-window variation are
>         entered into the box plot at b_s = 0 rather than being silently
>         dropped by the regression's SE filter.
> 
>     Outputs (under ${work}/results/figures/):
>         per_scandal_box_<outcome>_w30_presi_zero.pdf
>         per_scandal_jitter_<outcome>_w30_presi_zero.pdf
> ---------------------------------------------------------------------------- 
> */
. 
. if "`c(username)'" == "lalov" {
.         gl identity "C:/Users/lalov/ITAM Seira Research Dropbox/Eduardo River
> a"
. }

. if "`c(username)'" == "Rob_9" {
.         global identity "C:/Users/Rob_9/Dropbox"
. }

. if "`c(username)'" == "rob98" {
.         global identity "~/Dropbox"
. }

. 
. global work   "${identity}/Corrupcion/Protest_Work"

. global path   "${identity}/Corrupcion/WORKING FOLDER/Event Study - Scandals"

. global datfin "${path}/Data/final"

. global resout "${work}/results"

. global figout "${work}/results/figures"

. 
. local window_length = 30

. local outcome_list = "num_protests_MM num_violent_MM num_peaceful_MM governme
> nt_response_violent"

. local outcome_number : word count `outcome_list'

. local ci_level = 95

. local zcrit = invnormal(1 - (100-`ci_level')/200)

. 
. use "${datfin}/protests_scandals_30days_v3_with_lv_of_agent_involved.dta", cl
> ear

. drop if country == "Venezuela"
(3,374 observations deleted)

. keep if abs(window) <= `window_length'
(31,921 observations deleted)

. 
. egen scandal_enc = group(id)

. egen scandal_tag = tag(id)

. 
. gen double _sd = date if window == 0
(10,562 missing values generated)

. bysort scandal_enc (_sd): replace _sd = _sd[1]
(10440 real changes made)

. format _sd %td

. 
. bysort scandal_enc: egen _pm = mean(post)

. drop if _pm == 0 | _pm == 1
(0 observations deleted)

. drop _pm

. 
. quietly levelsof scandal_enc, local(slevels)

. local n_scandals : word count `slevels'

. display in yellow "Per-scandal regressions: `n_scandals' scandals (ZERO-IMPUT
> ED)"
Per-scandal regressions: 176 scandals (ZERO-IMPUTED)

. 
. preserve

.         keep if scandal_tag == 1
(10,560 observations deleted)

.         keep scandal_enc id country official_involved _sd

.         rename _sd scandal_date

.         tempfile metadata

.         save `metadata'
file C:\Users\rob98\AppData\Local\Temp\ST_6ec0_000002.tmp saved as .dta
    format

. restore

. 
. matrix define scandal_info = J(`n_scandals', 3*`outcome_number', .)

. matrix define zero_flag    = J(`n_scandals',   `outcome_number', 0)

. 
. forvalues s = 1/`n_scandals' {
  2.         local oc = 0
  3.         foreach outcome of local outcome_list {
  4.                 local ++oc
  5.                 quietly summarize `outcome' if scandal_enc == `s'
  6.                 local n_obs  = r(N)
  7.                 local sd_out = cond(r(N) > 1, r(sd), .)
  8.                 if `n_obs' > 30 {
  9.                         if `sd_out' == 0 & !missing(`sd_out') {
 10.                                 matrix scandal_info[`s', 3*`oc'-2] = 0
 11.                                 matrix scandal_info[`s', 3*`oc'-1] = .
 12.                                 matrix scandal_info[`s', 3*`oc']   = `n_ob
> s'
 13.                                 matrix zero_flag[`s', `oc']        = 1
 14.                         }
 15.                         else {
 16.                                 capture reghdfe `outcome' post if scandal_
> enc == `s', ///
>                                         absorb(month day) vce(robust)
 17.                                 if _rc == 0 & !missing(_b[post]) & _se[pos
> t] < . & _se[post] > 0 {
 18.                                         matrix scandal_info[`s', 3*`oc'-2]
>  = _b[post]
 19.                                         matrix scandal_info[`s', 3*`oc'-1]
>  = _se[post]
 20.                                         matrix scandal_info[`s', 3*`oc']  
>  = `n_obs'
 21.                                 }
 22.                         }
 23.                 }
 24.         }
 25. }

. 
. clear

. svmat scandal_info
number of observations will be reset to 176
Press any key to continue, or Break to abort
Number of observations (_N) was 0, now 176.

. svmat zero_flag, names(zflag)

. generate scandal_enc = _n

. merge 1:1 scandal_enc using `metadata', nogenerate

    Result                      Number of obs
    -----------------------------------------
    Not matched                             0
    Matched                               176  
    -----------------------------------------

. 
. local oc = 0

. foreach outcome of local outcome_list {
  2.         local ++oc
  3.         rename scandal_info`=3*`oc'-2' b_`outcome'
  4.         rename scandal_info`=3*`oc'-1' se_`outcome'
  5.         rename scandal_info`=3*`oc''   n_`outcome'
  6.         rename zflag`oc' zero_`outcome'
  7. }

. 
. preserve

.         import delimited using "${datfin}/scandals_classified.csv", ///
>                 clear varnames(1) bindquotes(strict)
(encoding automatically selected: UTF-8)
(7 vars, 190 obs)

.         keep id country position

.         tempfile cls

.         save `cls'
file C:\Users\rob98\AppData\Local\Temp\ST_6ec0_000004.tmp saved as .dta
    format

. restore

. merge 1:1 id country using `cls', keep(1 3) nogenerate

    Result                      Number of obs
    -----------------------------------------
    Not matched                             0
    Matched                               176  
    -----------------------------------------

. 
. gen byte presi = .
(176 missing values generated)

. replace presi = 1 if position == "president"
(45 real changes made)

. replace presi = 2 if !missing(position) & position != "president"
(131 real changes made)

. label define PRESI 1 "President" 2 "Others", replace

. label values presi PRESI

. 
. order scandal_enc id country official_involved position presi scandal_date //
> /
>         b_* se_* n_* zero_*

. compress
  variable scandal_enc was float now int
  variable official_involved was float now byte
  variable n_num_protests_MM was float now byte
  variable n_num_violent_MM was float now byte
  variable n_num_peaceful_MM was float now byte
  variable n_government_response_violent was float now byte
  variable zero_num_protests_MM was float now byte
  variable zero_num_violent_MM was float now byte
  variable zero_num_peaceful_MM was float now byte
  variable zero_government_response_violent was float now byte
  variable scandal_date was double now int
  variable country was str44 now str18
