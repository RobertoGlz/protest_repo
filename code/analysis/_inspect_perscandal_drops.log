. do _inspect_perscandal_drops.do 

. /* Quick diagnostic: of the 176 scandals, how many drop out of the
>    per-scandal boxplot for each outcome and why?
> 
>    We re-trace the filter inside per_scandal_effects_apex_v2.do:
>         (a) need > 30 non-missing observations of outcome in the
>             scandal's +-30-day window;
>         (b) reghdfe must converge (rc == 0);
>         (c) _b[post] and _se[post] must be finite and SE > 0.
> 
>    For each scandal, we tag which filter killed it. */
. 
. if "`c(username)'" == "rob98" {
.         global identity "~/Dropbox"
. }

. global path   "${identity}/Corrupcion/WORKING FOLDER/Event Study - Scandals"

. global datfin "${path}/Data/final"

. 
. use "${datfin}/protests_scandals_30days_v3_with_lv_of_agent_involved.dta", cl
> ear

. drop if country == "Venezuela"
(3,374 observations deleted)

. keep if abs(window) <= 30
(31,921 observations deleted)

. egen scandal_enc = group(id)

. 
. quietly levelsof scandal_enc, local(slevels)

. local n_scandals : word count `slevels'

. 
. /* For each outcome, build per-scandal status flags */
. foreach outcome in num_protests_MM num_violent_MM num_peaceful_MM {
  2.         preserve
  3.                 matrix DR = J(`n_scandals', 5, .)
  4.                 /* columns: nobs, sd_outcome, rc, b_post, se_post */
.                 forvalues s = 1/`n_scandals' {
  5.                         quietly count if !missing(`outcome') & scandal_enc
>  == `s'
  6.                         matrix DR[`s', 1] = r(N)
  7.                         quietly summarize `outcome' if scandal_enc == `s'
  8.                         matrix DR[`s', 2] = r(sd)
  9.                         if r(N) > 30 {
 10.                                 capture reghdfe `outcome' post if scandal_
> enc == `s', ///
>                                         absorb(month day) vce(robust)
 11.                                 matrix DR[`s', 3] = _rc
 12.                                 if _rc == 0 {
 13.                                         matrix DR[`s', 4] = _b[post]
 14.                                         matrix DR[`s', 5] = _se[post]
 15.                                 }
 16.                         }
 17.                 }
 18.                 clear
 19.                 svmat DR
 20.                 rename (DR1 DR2 DR3 DR4 DR5) (nobs sd_out rc b_post se_pos
> t)
 21.                 gen byte filt = .
 22.                 replace filt = 1 if nobs <= 30
 23.                 replace filt = 2 if filt == . & rc != 0
 24.                 replace filt = 3 if filt == . & (missing(b_post) | missing
> (se_post))
 25.                 replace filt = 4 if filt == . & se_post == 0
 26.                 replace filt = 0 if filt == . & se_post > 0 & !missing(b_p
> ost)
 27.                 label define FILT 0 "Kept" 1 "Too few obs (nobs<=30)" ///
>                         2 "reghdfe rc!=0" 3 "missing b/se" 4 "se_post==0 (no 
> variance)", replace
 28.                 label values filt FILT
 29.                 display _newline "=== Drop diagnostics for `outcome' ==="
 30.                 tab filt, missing
 31.                 display _newline "    Outcome SD distribution among DROPPE
> D scandals (filt!=0):"
 32.                 tabstat sd_out if filt != 0, statistics(n mean p50 min max
> )
 33.                 display _newline "    Outcome SD distribution among KEPT s
> candals (filt==0):"
 34.                 tabstat sd_out if filt == 0, statistics(n mean p50 min max
> )
 35.         restore
 36. }
