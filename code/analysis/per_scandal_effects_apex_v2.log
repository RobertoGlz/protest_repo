. /* ============================================================
>    PLOTS: BOX (no outliers) AND JITTER
>         Note format follows the standard adopted on 2026-06-27:
>            "Median <label> = <p50>     (Scandals = <count>)"
>    ============================================================ */
. foreach outcome of local outcome_list {
  2. 
.         if "`outcome'" == "num_protests_MM"             local ytitle "protest
> s (any)"
  3.         if "`outcome'" == "num_violent_MM"              local ytitle "viol
> ent protests"
  4.         if "`outcome'" == "num_peaceful_MM"             local ytitle "peac
> eful protests"
  5.         if "`outcome'" == "government_response_violent" local ytitle "gvt.
>  violent response"
  6. 
.         display in yellow "=== Per-scandal `outcome': by apex_cat (v2) ==="
  7.         tabstat b_`outcome', by(apex_cat) ///
>                 statistics(n mean p50 sd min max) columns(statistics)
  8.         mean b_`outcome', over(apex_cat)
  9. 
.         /* Per-category note: one row per category */
.         quietly levelsof apex_cat, local(__cats)
 10.         local med_note `""'
 11.         foreach c of local __cats {
 12.                 quietly summarize b_`outcome' if apex_cat == `c', detail
 13.                 local __mstr = string(r(p50), "%5.3f")
 14.                 quietly count if !missing(b_`outcome') & apex_cat == `c'
 15.                 local __nstr = r(N)
 16.                 local __lbl : label APEX `c'
 17.                 local med_note `"`med_note' "Median `__lbl' = `__mstr'    
>  (Scandals = `__nstr')""'
 18.         }
 19. 
.         /* ---- (a) box plot ---- */
.         graph box b_`outcome', over(apex_cat, label(labsize(large))) ///
>                 nooutsides ///
>                 ytitle("Per-scandal effect on `ytitle'", size(medlarge)) ///
>                 ylabel(, format(%4.2f) angle(0) labsize(large)) ///
>                 yline(0, lpattern(dash) lcolor(gs8)) ///
>                 note(`med_note', size(medlarge)) ///
>                 medtype(line) ///
>                 box(1, lcolor(black) lwidth(thick)) ///
>                 box(2, lcolor(black) lwidth(thick)) ///
>                 box(3, lcolor(black) lwidth(thick)) ///
>                 scheme(s2color) graphregion(color(white))
 20.         graph export ///
>                 "${figout}/per_scandal_box_`outcome'_w`window_length'_apex_v2
> .pdf", replace
 21. 
.         /* ---- (b) jittered scatter with category mean + 95% CI ---- */
.         preserve
 22.                 keep if !missing(b_`outcome') & !missing(apex_cat)
 23.                 generate double prec = 1 / se_`outcome'^2
 24.                 quietly summarize prec
 25.                 replace prec = prec / r(max)
 26. 
.                 quietly levelsof apex_cat, local(cats)
 27.                 gen double cmean = .
 28.                 gen double clo   = .
 29.                 gen double chi   = .
 30.                 foreach c of local cats {
 31.                         quietly count if apex_cat == `c'
 32.                         if r(N) >= 2 {
 33.                                 quietly mean b_`outcome' if apex_cat == `c
> '
 34.                                 matrix mb = r(table)
 35.                                 quietly replace cmean = mb[1,1] if apex_ca
> t == `c'
 36.                                 quietly replace clo   = mb[5,1] if apex_ca
> t == `c'
 37.                                 quietly replace chi   = mb[6,1] if apex_ca
> t == `c'
 38.                         }
 39.                 }
 40. 
.                 twoway ///
>                         (scatter b_`outcome' apex_cat [aw=prec], ///
>                                 jitter(8) mcolor(navy%35) msymbol(O)) ///
>                         (rcap clo chi apex_cat, lcolor(black) lwidth(medthick
> )) ///
>                         (scatter cmean apex_cat, mcolor(black) msymbol(D) msi
> ze(medlarge)), ///
>                         yline(0, lpattern(dash) lcolor(gs8)) ///
>                         ytitle("Per-scandal effect on `ytitle'") ///
>                         xtitle("Apex partition (v2)") ///
>                         xlabel(1 "President" 2 "Other Apex" 3 "Other Non-Apex
> ", noticks) ///
>                         xscale(range(0.5 3.5)) ///
>                         ylabel(, format(%4.2f) angle(0)) ///
>                         legend(order(3 "Category mean" 2 "95% CI" 1 "Per-scan
> dal b") ///
>                                 pos(1) ring(0) region(lcolor(gs10)) size(smal
> l) cols(1)) ///
>                         note("Each point is one scandal; marker size proporti
> onal to 1/SE^2." ///
>                                 "Narrow +-`window_length'-day window; classif
> ication v2.") ///
>                         scheme(s2color) graphregion(color(white))
 41.                 graph export ///
>                         "${figout}/per_scandal_jitter_`outcome'_w`window_leng
> th'_apex_v2.pdf", replace
 42.         restore
 43. }
