. do "${progdir}/define_panelcombine.do"

. /* ----------------------------------------------------------------------------
>    Project: Apex corruption protests paper
> 
>    Code author: steveofconnell (original)
>    Modifications: Roberto Gonzalez
> 
>    Objective: Define a panelcombine program that handles booktabs rules
>               rather than hlines. Source the program at the top of any
>               analysis do-file that builds a multi-panel table.
> 
>    Source of the original program:
>      https://raw.githubusercontent.com/steveofconnell/PanelCombine/master/PanelCombine.do
>    Copied verbatim from the religion_project_repo project's
>      code/programs/define_panelcombine.do
>    so this project does not depend on a sibling repository at build time.
> ---------------------------------------------------------------------------- */
. 
. cap prog drop panelcombine

. prog define panelcombine
  1. qui {
  2. syntax, use(str asis) paneltitles(str asis) columncount(integer) save(str) [CLEANup]
  3. preserve
  4. 
. tokenize `"`paneltitles'"'
  5. //read in loop
. local num 1
  6. while "``num''"~="" {
  7. local panel`num'title="``num''"
  8. local num=`num'+1
  9. }
 10. 
. 
. tokenize `"`use'"'
 11. //read in loop
. local num 1
 12. while `"``num''"'~="" {
 13. local filepath `"``num''"'
 14. tempfile temp`num'
 15. insheet using `"`filepath'"', clear
 16. save `temp`num''
 17. local max = `num'
 18. local num=`num'+1
 19. }
 20. 
. //conditional processing loop
. tokenize `"`use'"'
 21. local num 1
 22. while `"``num''"'~="" {
 23. local panellabel : word `num' of `c(ALPHA)'
 24. use `temp`num'', clear
 25.         if `num'==1 { //process first panel -- clip bottom
 26.         drop if strpos(v1,"Note:")>0 | strpos(v1,"in parentheses")>0 | strpos(v1,"p<0")>0
 27.         drop if v1=="\end{tabular}" | v1=="}"
 28.         /* Replace ONLY the first occurrence of \midrule with the Panel A
>            header. Using cumulative-sum-of-flag is robust to the row
>            position changing because of mgroups, multi-row column
>            headers, etc. */
.         gen byte _is_mid = (v1 == "\midrule")
 29.         gen long _midnum = sum(_is_mid)
 30.         replace v1 = "\midrule \multicolumn{`columncount'}{l}{\textbf{\textit{Panel `panellabel': `panel1title'}}} \\" if _is_mid == 1 & _midnum == 1
 31.         drop _is_mid _midnum
 32.         replace v1 = "\midrule" if v1=="\bottomrule" & _n>4 //this is intended to replace the bottom double line; more robust condition probably exists
 33.         }
 34.         else if `num'==`max' { //process final panel -- clip top
 35.         //process header to drop everything until first hline
.         g temp = (v1 == "\midrule")
 36.         replace temp = temp+temp[_n-1] if _n>1
 37.         drop if temp==0
 38.         drop temp
 39. 
.         replace v1 = " \multicolumn{`columncount'}{l}{\textbf{\textit{Panel `panellabel': `panel`num'title'}}} \\" if _n==1
 40.         }
 41.         else { //process middle panels -- clip top and bottom
 42.         //process header to drop everything until first hline
.         g temp = (v1 == "\midrule")
 43.         replace temp = temp+temp[_n-1] if _n>1
 44.         drop if temp==0
 45.         drop temp
 46. 
.         replace v1 = " \multicolumn{`columncount'}{l}{\textbf{\textit{Panel `panellabel': `panel`num'title'}}} \\" if _n==1
 47.         drop if strpos(v1,"Note:")>0 | strpos(v1,"in parentheses")>0 | strpos(v1,"p<0")>0
 48.         drop if v1=="\end{tabular}" | v1=="}"
 49.         replace v1 = "\bottomrule" if v1=="\bottomrule\bottomrule"
 50.         }
 51.         save `temp`num'', replace
 52. local num=`num'+1
 53. }
 54. 
. use `temp1',clear
 55. local num 2
 56. while "``num''"~="" {
 57. append using `temp`num''
 58. local num=`num'+1
 59. }
 60. 
. outsheet using `save', noname replace noquote
 61. 
. 
.         if "`cleanup'"!="" { //erasure loop
 62.         tokenize `"`use'"'
 63.         local num 1
 64.                 while `"``num''"'~="" {
 65.                 local filepath `"``num''"'
 66.                 erase `"`filepath'"'
 67.                 local num=`num'+1
 68.                 }
 69.         }
 70. 
. restore
 71. }
 72. end

. 
end of do-file

. 
. global fe1      "i.country_id#i.year"

. global CLUSTER2 "cluster i.country_id#i.year#i.grupo_dias"

. local  firstyear = 2008

. 
. /* ============================================================
>    Loop over estimator (ols/poi) and panel.  Each panel loads its
>    OWN source dataset directly from disk and builds the share
>    outcomes inline -- no pre-built tempfiles, no helper programs.
>    ============================================================ */
. foreach est in ols poi {
  2. 
.         if "`est'" == "ols" {
  3.                 local out_list "num_violent_MM num_peaceful_MM num_violent_MM num_peaceful_MM share_violent share_peaceful share_violent share_peaceful"
  4.                 local win_list "30 30 120 120 30 30 120 120"
  5.         }
  6.         else {
  7.                 local out_list "num_violent_MM num_peaceful_MM num_violent_MM num_peaceful_MM"
  8.                 local win_list "30 30 120 120"
  9.         }
 10.         local ncell : word count `out_list'
 11. 
.         foreach p in corrpa corrna football deprec {
 12. 
.                 /* ---------- load + prep this panel's data ---------- */
.                 if "`p'" == "corrpa" | "`p'" == "corrna" {
 13.                         import delimited using "${datfin}/scandals_classified.csv", ///
>                                 clear varnames(1) bindquotes(strict)
 14.                         keep id country position
 15.                         tempfile cls
 16.                         save `cls'
 17. 
.                         use "${datfin}/protests_scandals_30days_v3", clear
 18.                         drop if country == "Venezuela"
 19.                         merge m:1 id country using `cls', keep(1 3) nogenerate
 20. 
.                         gen byte in_pa = 0
 21.                         replace in_pa = 1 if position == "president"
 22.                         replace in_pa = 1 if position == "governor"
 23.                         replace in_pa = 1 if position == "sc_judge_congressman" & ///
>                                 inlist(id, "202", "NEW26", "NEW30", "332", "NEW23")
 24. 
.                         gen byte in_na = 0
 25.                         replace in_na = 1 if position == "sc_judge_congressman" & ///
>                                 !inlist(id, "202", "NEW26", "NEW30", "332", "NEW23")
 26.                         replace in_na = 1 if position == "other_judiciary"
 27.                         replace in_na = 1 if position == "others"
 28. 
.                         if "`p'" == "corrpa" local flag "in_pa"
 29.                         else                 local flag "in_na"
 30.                 }
 31.                 else if "`p'" == "football" {
 32.                         use "${datfin}/protests_scandals_30days_football_v3", clear
 33.                         drop if country == "Venezuela"
 34.                         gen byte keepall = 1
 35.                         local flag "keepall"
 36.                 }
 37.                 else if "`p'" == "deprec" {
 38.                         use "${datfin}/protests_scandals_30days_depreciation_v3", clear
 39.                         drop if country == "Venezuela"
 40.                         gen byte keepall = 1
 41.                         local flag "keepall"
 42.                 }
 43. 
.                 /* share outcomes (0 imputed on no-protest days) */
.                 capture confirm variable num_protests_MM
 44.                 if _rc gen double num_protests_MM = num_violent_MM + num_peaceful_MM
 45.                 gen double share_violent  = num_violent_MM  / num_protests_MM if num_protests_MM > 0
 46.                 gen double share_peaceful = num_peaceful_MM / num_protests_MM if num_protests_MM > 0
 47.                 replace    share_violent  = 0 if num_protests_MM == 0
 48.                 replace    share_peaceful = 0 if num_protests_MM == 0
 49. 
.                 egen grupo_dias = group(s_lag30 s_lag60 s_lag90 s_lag120 ///
>                                         s_lead30 s_lead60 s_lead90 s_lead120)
 50. 
.                 tempfile pdata
 51.                 save `pdata'
 52. 
.                 /* ---------- run the cells on this panel's data ---------- */
.                 eststo clear
 53.                 forvalues k = 1/`ncell' {
 54.                         local outcome : word `k' of `out_list'
 55.                         local window  : word `k' of `win_list'
 56.                         local bin_size = cond(`window' == 30, 6, 30)
 57. 
.                         use `pdata', clear
 58.                         if "`est'" == "ols" {
 59.                                 if `window' == 30 {
 60.                                         eststo m`k': reghdfe `outcome' post i.month i.day ///
>                                                 if year >= `firstyear' & abs(window) <= 30 & `flag' == 1, ///
>                                                 absorb($fe1) vce($CLUSTER2)
 61.                                 }
 62.                                 else {
 63.                                         eststo m`k': reghdfe `outcome' post i.month i.day ///
>                                                 if year >= `firstyear' & `flag' == 1, ///
>                                                 absorb($fe1) vce($CLUSTER2)
 64.                                 }
 65.                         }
 66.                         else {
 67.                                 if `window' == 30 {
 68.                                         capture eststo m`k': ppmlhdfe `outcome' post ///
>                                                 if year >= `firstyear' & abs(window) <= 30 & `flag' == 1, ///
>                                                 absorb(month day $fe1) vce($CLUSTER2)
 69.                                 }
 70.                                 else {
 71.                                         capture eststo m`k': ppmlhdfe `outcome' post ///
>                                                 if year >= `firstyear' & `flag' == 1, ///
>                                                 absorb(month day $fe1) vce($CLUSTER2)
 72.                                 }
 73.                         }
 74. 
.                         quietly summarize `outcome' if e(sample) ///
>                                 & window >= -`bin_size' & window <= -1
 75.                         estadd scalar baseline = r(mean)
 76. 
.                         capture quietly levelsof id if e(sample) == 1
 77.                         if _rc == 0 estadd scalar num_events = r(r)
 78.                 }
 79. 
.                 /* ---------- write this panel's temp table(s) ---------- */
.                 if "`est'" == "ols" {
 80.                         /* 4-column (counts only): appendix Table S7 layout */
.                         esttab m1 m2 m3 m4 using "${tables}/bench_ols4_`p'_temp.tex", ///
>                                 replace booktabs nonotes nogaps b(3) se(3) ///
>                                 star(* 0.10 ** 0.05 *** 0.01) ///
>                                 mtitles("\shortstack{Violent\\Protests}" ///
>                                         "\shortstack{Peaceful\\Protests}" ///
>                                         "\shortstack{Violent\\Protests}" ///
>                                         "\shortstack{Peaceful\\Protests}") ///
>                                 mgroups("$\pm 30$-Day Window" "$\pm 120$-Day Window", ///
>                                         pattern(1 0 1 0) ///
>                                         prefix(\multicolumn{2}{c}{) suffix(}) span ///
>                                         erepeat(\cmidrule(lr){@span})) ///
>                                 stats(baseline N num_events r2, ///
>                                       label("Mean (Pre-Event Bin)" "Observations" ///
>                                             "Number of Events" "R-squared") ///
>                                       fmt(3 0 0 3)) ///
>                                 keep(post) coeflabels(post "Post Event")
 81. 
.                         /* 8-column (counts + shares): comparable to Table 1 */
.                         esttab m1 m2 m3 m4 m5 m6 m7 m8 using "${tables}/bench_ols8_`p'_temp.tex", ///
>                                 replace booktabs nonotes nogaps b(3) se(3) ///
>                                 star(* 0.10 ** 0.05 *** 0.01) ///
>                                 mtitles("\shortstack{Violent\\Protests}" ///
>                                         "\shortstack{Peaceful\\Protests}" ///
>                                         "\shortstack{Violent\\Protests}" ///
>                                         "\shortstack{Peaceful\\Protests}" ///
>                                         "\shortstack{Share\\Violent}" ///
>                                         "\shortstack{Share\\Peaceful}" ///
>                                         "\shortstack{Share\\Violent}" ///
>                                         "\shortstack{Share\\Peaceful}") ///
>                                 mgroups("$\pm 30$-Day Window" "$\pm 120$-Day Window" ///
>                                         "Shares ($\pm 30$-Day)" "Shares ($\pm 120$-Day)", ///
>                                         pattern(1 0 1 0 1 0 1 0) ///
>                                         prefix(\multicolumn{2}{c}{) suffix(}) span ///
>                                         erepeat(\cmidrule(lr){@span})) ///
>                                 stats(baseline N num_events r2, ///
>                                       label("Mean (Pre-Event Bin)" "Observations" ///
>                                             "Number of Events" "R-squared") ///
>                                       fmt(3 0 0 3)) ///
>                                 keep(post) coeflabels(post "Post Event")
 82.                 }
 83.                 else {
 84.                         esttab m1 m2 m3 m4 using "${tables}/bench_poi_`p'_temp.tex", ///
>                                 replace booktabs nonotes nogaps b(3) se(3) eform ///
>                                 star(* 0.10 ** 0.05 *** 0.01) ///
>                                 mtitles("\shortstack{Violent\\Protests}" ///
>                                         "\shortstack{Peaceful\\Protests}" ///
>                                         "\shortstack{Violent\\Protests}" ///
>                                         "\shortstack{Peaceful\\Protests}") ///
>                                 mgroups("$\pm 30$-Day Window" "$\pm 120$-Day Window", ///
>                                         pattern(1 0 1 0) ///
>                                         prefix(\multicolumn{2}{c}{) suffix(}) span ///
>                                         erepeat(\cmidrule(lr){@span})) ///
>                                 stats(baseline N num_events r2_p, ///
>                                       label("Mean (Pre-Event Bin)" "Observations" ///
>                                             "Number of Events" "Pseudo R-squared") ///
>                                       fmt(3 0 0 3)) ///
>                                 keep(post) coeflabels(post "Post Event (IRR)")
 85.                 }
 86.         }
 87. 
.         /* ---------- combine the four panels ---------- */
.         if "`est'" == "ols" {
 88.                 panelcombine, ///
>                         use("${tables}/bench_ols4_corrpa_temp.tex" ///
>                             "${tables}/bench_ols4_corrna_temp.tex" ///
>                             "${tables}/bench_ols4_football_temp.tex" ///
>                             "${tables}/bench_ols4_deprec_temp.tex") ///
>                         paneltitles("Apex corruption (President + Other Apex)" ///
>                                     "Non-apex corruption (Other Non-Apex)" ///
>                                     "Football match losses" ///
>                                     "Currency depreciations") ///
>                         columncount(5) ///
>                         save("${tables}/sup_benchmarks_ols_panels.tex") ///
>                         cleanup
 89. 
.                 panelcombine, ///
>                         use("${tables}/bench_ols8_corrpa_temp.tex" ///
>                             "${tables}/bench_ols8_corrna_temp.tex" ///
>                             "${tables}/bench_ols8_football_temp.tex" ///
>                             "${tables}/bench_ols8_deprec_temp.tex") ///
>                         paneltitles("Apex corruption (President + Other Apex)" ///
>                                     "Non-apex corruption (Other Non-Apex)" ///
>                                     "Football match losses" ///
>                                     "Currency depreciations") ///
>                         columncount(9) ///
>                         save("${tables}/sup_benchmarks_ols_panels_shares.tex") ///
>                         cleanup
 90.         }
 91.         else {
 92.                 panelcombine, ///
>                         use("${tables}/bench_poi_corrpa_temp.tex" ///
>                             "${tables}/bench_poi_corrna_temp.tex" ///
>                             "${tables}/bench_poi_football_temp.tex" ///
>                             "${tables}/bench_poi_deprec_temp.tex") ///
>                         paneltitles("Apex corruption (President + Other Apex)" ///
>                                     "Non-apex corruption (Other Non-Apex)" ///
>                                     "Football match losses" ///
>                                     "Currency depreciations") ///
>                         columncount(5) ///
>                         save("${tables}/sup_benchmarks_poi_panels.tex") ///
>                         cleanup
 93.         }
 94. }
