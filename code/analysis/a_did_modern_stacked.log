  5.                 local s = se_`er'_`oc'
  6.                 local bs = cond(missing(`b'), "    .    ", string(`b', "%9
> .5f"))
  7.                 local ss = cond(missing(`s'), "    .    ", string(`s', "%9
> .5f"))
  8.                 local row "`row'  `bs' (`ss')"
  9.         }
