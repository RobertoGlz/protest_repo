  4.         local ac_var "`2'"
  5.         local out    "`3'"
  6.         quietly count if `mm_var' == 0 & `ac_var' == 0
  7.         local n00 = r(N)
  8.         quietly count if `mm_var' == 1 & `ac_var' == 0
  9.         local n10 = r(N)
 10.         quietly count if `mm_var' == 0 & `ac_var' == 1
 11.         local n01 = r(N)
 12.         quietly count if `mm_var' == 1 & `ac_var' == 1
 13.         local n11 = r(N)
 14.         quietly kap `mm_var' `ac_var'
 15.         local k = r(kappa)
 16.         preserve
 17.                 use `twoxtwo', clear
 18.                 insobs 1
 19.                 replace outcome    = "`out'" in L
 20.                 replace n_neither  = `n00' in L
 21.                 replace n_mm_only  = `n10' in L
 22.                 replace n_ac_only  = `n01' in L
 23.                 replace n_both     = `n11' in L
 24.                 replace kappa      = `k'   in L
 25.                 save `twoxtwo', replace
 26.         restore
 27. }
