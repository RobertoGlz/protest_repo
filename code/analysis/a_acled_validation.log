. /* --- (a) slope and R^2: MM count ~ ACLED count, by outcome --- */
. estimates clear

. di as result "=== Slope/R^2: MM = a + b * ACLED ==="
=== Slope/R^2: MM = a + b * ACLED ===

. foreach pair in "num_protests_MM num_protests_ACLED" ///
>                 "num_violent_MM num_violent_ACLED" ///
>                 "num_peaceful_MM num_peaceful_ACLED" {
  2.         tokenize `pair'
  3.         local mm_var "`1'"
  4.         local ac_var "`2'"
  5.         eststo `mm_var' : regress `mm_var' `ac_var'
  6.         local b  = string(_b[`ac_var'], "%9.5f")
  7.         local se = string(_se[`ac_var'], "%9.5f")
  8.         local r2 = string(e(r2), "%5.3f")
  9.         local r2a = string(e(r2_a), "%5.3f")
 10.         display ///
>                 "`mm_var' ~ `ac_var':  slope = `b' (se `se')   R2 = `r2'  R2_
> adj = `r2a'"
 11. }

