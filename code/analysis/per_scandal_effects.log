. do per_scandal_effects.do 

. /* --------------------------------------------------------------------------
> --
>                                                 Violent effects of apex corru
> ption
> 
>         Code author: Roberto Gonzalez
>         Date: April 29, 2026  (rewritten 2026-05-15 to match the actual
>                 protests_scandals_30days_v3_with_lv_of_agent_involved.dta sch
> ema)
> 
>         Objective (protests_plan.md, Task 5):
>                 For each scandal, run the within-window pre/post regression o
> n its
>                 own country and extract a single `Post Scandal` coefficient.
>                 Plot the distribution of those per-scandal coefficients by th
> e type
>                 of official involved (1 President, 2 Supreme Court Judge/Secr
> etary,
>                 3 Others).
> 
>         Design (per the plan):
>                 - Per scandal s: reghdfe outcome post, absorb(month dow) on t
> he
>                   narrow +-30-day window of that scandal's country.  Fewer ob
> s but
>                   tighter identification than +-120.
>                 - Save (scandal_id, official_involved, b_s, se_s, n_s).
>                 - Plot: jittered scatter of b_s by official type, overlaid wi
> th the
>                   category mean and its 95% CI (more honest than graph box be
> cause
>                   it shows the small-N categories).  Marker size ~ 1/se_s^2 s
> o the
>                   eye does not confuse a noisy b_s with a sharp one.  A compa
> nion
>                   box plot is also produced.
> 
>         Caveat: with one country and a +-30-day window each per-scandal
>         regression has very limited leverage; individual b_s are noisy by
>         construction.  The object of interest is the *distribution*, not any
>         single estimate.
> ---------------------------------------------------------------------------- 
> */
. 
. /* ------------------- Configuration for collaborators -------------------- *
> /
. if "`c(username)'" == "lalov" {
.         gl identity "C:/Users/lalov/ITAM Seira Research Dropbox/Eduardo River
> a"
. }

. if "`c(username)'" == "Rob_9" {
.         global identity "C:/Users/Rob_9/Dropbox"
. }

. if "`c(username)'" == "rob98" {
.         global identity "~/Dropbox"
. }

. 
. global work "${identity}/Corrupcion/Protest_Work"

. 
. /* Creating Global File Paths ---------------------------------------------- 
> */
. global path     "${identity}/Corrupcion/WORKING FOLDER/Event Study - Scandals
> "

. global datfin   "${path}/Data/final"

. global output   "${path}/Output"

. global graphs   "${output}/Graphs"

. global tables   "${output}/Tables"

. global figout   "${work}/results/figures"

. global resout   "${work}/results"

. /* ------------------------------------------------------------------------- 
> */
. 
. /* Narrow window per the plan */
. local window_length = 30

. 
. /* Outcomes (mirrors the 4-outcome panels in Protests.pdf) */
. local outcome_list = "num_protests_MM num_violent_MM num_peaceful_MM governme
> nt_response_violent"

. local outcome_number : word count `outcome_list'

. 
. /* CI level for the category-mean overlay and the exported per-scandal CIs */
. local ci_level = 95

. local zcrit = invnormal(1 - (100-`ci_level')/200)

. 
. /* ============================================================
>    READ AND PREPARE
>    ============================================================ */
. 
. use "${datfin}/protests_scandals_30days_v3_with_lv_of_agent_involved.dta", cl
> ear

. drop if country == "Venezuela"
(3,374 observations deleted)

. 
. /* Merge in scandals_classified.csv to get the position + political_affiliati
> on
>    labels used by ppmlhdfe_main_by_position.do and by the PDF's Tables 12-15
>    incumbent / non-incumbent panels.  172/176 scandals match; the 4 unmatched
>    fall through to the "Others" category below. */
. preserve

.         import delimited using "${datfin}/scandals_classified.csv", ///
>                 clear varnames(1) bindquotes(strict)
(encoding automatically selected: UTF-8)
(7 vars, 186 obs)

.         keep id country position political_affiliation

.         tempfile cls

.         save `cls'
file C:\Users\rob98\AppData\Local\Temp\ST_a454_000002.tmp saved as .dta
    format

. restore

. merge m:1 id country using `cls', keep(1 3) nogenerate

    Result                      Number of obs
    -----------------------------------------
    Not matched                           964
        from master                       964  
        from using                          0  

    Matched                            41,693  
    -----------------------------------------

. 
. /* Refined 5-way categorisation that matches the PDF heterogeneity panels:
>      1 Incumbent President     (position=="president"  & incumbent)
>      2 Non-Incumbent President (position=="president"  & !incumbent)
>      3 Incumbent Governor      (position=="governor"   & incumbent)
>      4 SCJ / Congressman       (position in sc_judge_congressman, other_judic
> iary)
>      5 Others                  (everything else, incl. unmatched and non-incu
> mbent
>                                 governors)
> */
. gen byte official_class = .
(42,657 missing values generated)

. replace official_class = 1 if position == "president" & political_affiliation
>  == "incumbent"
(5,784 real changes made)

. replace official_class = 2 if position == "president" & political_affiliation
>  != "incumbent" ///
>         & !missing(political_affiliation)
(5,061 real changes made)

. replace official_class = 3 if position == "governor"  & political_affiliation
>  == "incumbent"
(1,446 real changes made)

. replace official_class = 4 if inlist(position, "sc_judge_congressman", "other
> _judiciary")
(7,953 real changes made)

. replace official_class = 5 if missing(official_class)
(22,413 real changes made)

. 
. label define OCLASS ///
>         1 "Inc. President" ///
>         2 "Non-Inc. President" ///
>         3 "Inc. Governor" ///
>         4 "SCJ/Congressman" ///
>         5 "Others", replace

. label values official_class OCLASS

. 
. /* event-time variable in this dataset is `window`; restrict to +-30 days */
. keep if abs(window) <= `window_length'
(31,921 observations deleted)

. 
. /* Numeric per-scandal id (id is the str scandal identifier; one scandal
>    belongs to exactly one country, so id alone identifies a scandal-country) 
> */
. egen scandal_enc = group(id)

. egen scandal_tag = tag(id)

. 
. /* Scandal date = calendar date at window == 0 (carried to every row) */
. gen double _sd = date if window == 0
(10,562 missing values generated)

. bysort scandal_enc (_sd): replace _sd = _sd[1]
(10440 real changes made)

. format _sd %td

. 
. /* Defensive: drop scandals with no within-window post variation
>    (diagnostics showed 0 such scandals, but keep the guard) */
. bysort scandal_enc: egen _pm = mean(post)

. drop if _pm == 0 | _pm == 1
(0 observations deleted)

. drop _pm

. 
. /* month and dow already exist in the data (month = month(date),
>    day = dow(date), 0 = Sunday); use them directly as FE */
. 
. quietly levelsof scandal_enc, local(slevels)

. local n_scandals : word count `slevels'

. display in yellow "Per-scandal regressions: `n_scandals' scandals x `outcome_
> number' outcomes"
Per-scandal regressions: 176 scandals x 4 outcomes

. 
. /* One-row-per-scandal metadata to merge back after the matrix is filled */
. preserve

.         keep if scandal_tag == 1
(10,560 observations deleted)

.         keep scandal_enc id country official_involved official_class ///
>                 position political_affiliation _sd

.         rename _sd scandal_date

.         tempfile metadata

.         save `metadata'
file C:\Users\rob98\AppData\Local\Temp\ST_a454_000004.tmp saved as .dta
    format

. restore

. 
. /* ============================================================
>    PER-SCANDAL REGRESSIONS
>    ============================================================ */
. 
. matrix define scandal_info = J(`n_scandals', 3*`outcome_number', .)

. 
. forvalues s = 1/`n_scandals' {
  2.         local oc = 0
  3.         foreach outcome of local outcome_list {
  4.                 local ++oc
  5.                 quietly count if !missing(`outcome') & scandal_enc == `s'
  6.                 local nobs = r(N)
  7.                 if `nobs' > 30 {
  8.                         capture reghdfe `outcome' post if scandal_enc == `
> s', ///
>                                 absorb(month day) vce(robust)
  9.                         if _rc == 0 & !missing(_b[post]) & _se[post] < . &
>  _se[post] > 0 {
 10.                                 matrix scandal_info[`s', 3*`oc'-2] = _b[po
> st]
 11.                                 matrix scandal_info[`s', 3*`oc'-1] = _se[p
> ost]
 12.                                 matrix scandal_info[`s', 3*`oc']   = `nobs
> '
 13.                         }
 14.                 }
 15.         }
 16. }

. 
. /* Convert matrix to dataset and merge metadata back in */
. clear

. svmat scandal_info
number of observations will be reset to 176
Press any key to continue, or Break to abort
Number of observations (_N) was 0, now 176.

. generate scandal_enc = _n

. merge 1:1 scandal_enc using `metadata', nogenerate

    Result                      Number of obs
    -----------------------------------------
    Not matched                             0
    Matched                               176  
    -----------------------------------------

. 
. /* Name the columns: b_/se_/n_ per outcome */
. local oc = 0

. foreach outcome of local outcome_list {
  2.         local ++oc
  3.         rename scandal_info`=3*`oc'-2' b_`outcome'
  4.         rename scandal_info`=3*`oc'-1' se_`outcome'
  5.         rename scandal_info`=3*`oc''   n_`outcome'
  6.         /* per-scandal CI */
.         generate lb_`outcome' = b_`outcome' - `zcrit'*se_`outcome'
  7.         generate ub_`outcome' = b_`outcome' + `zcrit'*se_`outcome'
  8. }
(101 missing values generated)
(101 missing values generated)
(145 missing values generated)
(145 missing values generated)
(113 missing values generated)
(113 missing values generated)
(168 missing values generated)
(168 missing values generated)

. 
. label define OFF 1 "President" 2 "SCJ/Secretary" 3 "Others", replace

. label values official_involved OFF

. label define OCLASS ///
>         1 "Inc. President" ///
>         2 "Non-Inc. President" ///
>         3 "Inc. Governor" ///
>         4 "SCJ/Congressman" ///
>         5 "Others", replace

. label values official_class OCLASS

. 
. order scandal_enc id country official_involved official_class ///
>         position political_affiliation scandal_date b_* se_* n_* lb_* ub_*

. compress
  variable scandal_enc was float now int
  variable official_involved was float now byte
  variable n_num_protests_MM was float now byte
  variable n_num_violent_MM was float now byte
  variable n_num_peaceful_MM was float now byte
  variable n_government_response_violent was float now byte
  variable scandal_date was double now int
  variable country was str44 now str18
  (8,624 bytes saved)

. 
. /* ============================================================
>    EXPORT THE PER-SCANDAL ESTIMATES
>    ============================================================ */
. save   "${resout}/per_scandal_effects_w`window_length'.dta", replace
