. /* ============================================================
>    PLOTS BY TYPE OF OFFICIAL INVOLVED
>    Generates the jitter + box pair under both groupings (3-way and 5-way),
>    filename-suffixed with `_3cat` or `_5cat`.  The 5-way version is the
>    point of this revision (splits President by incumbency, isolates
>    Incumbent Governors -- mirrors the PDF's Tables 12/14 panels).
>    ============================================================ */
. foreach grouping in official_involved official_class {
  2. 
.         if "`grouping'" == "official_involved" {
  3.                 local suffix    = "3cat"
  4.                 local xlab      = `"1 "President" 2 "SCJ/Sec." 3 "Others""
> '
  5.                 local xmax      = 3
  6.         }
  7.         else {
  8.                 local suffix    = "5cat"
  9.                 local xlab      = `"1 "Inc. Pres" 2 "Non-Inc. Pres" 3 "Inc
> . Gov" 4 "SCJ/Cong" 5 "Others""'
 10.                 local xmax      = 5
 11.         }
 12. 
.         foreach outcome of local outcome_list {
 13. 
.                 if "`outcome'" == "num_protests_MM"             local ytitle 
> "protests (any)"
 14.                 if "`outcome'" == "num_violent_MM"              local ytit
> le "violent protests"
 15.                 if "`outcome'" == "num_peaceful_MM"             local ytit
> le "peaceful protests"
 16.                 if "`outcome'" == "government_response_violent" local ytit
> le "gvt. violent response"
 17. 
.                 /* ---- (a) jittered scatter with category mean + 95% CI over
> lay ---- */
.                 preserve
 18.                         keep if !missing(b_`outcome')
 19.                         generate double prec = 1 / se_`outcome'^2
 20.                         quietly summarize prec
 21.                         replace prec = prec / r(max)          /* normalize
>  to (0,1] */
 22. 
.                         quietly levelsof `grouping', local(cats)
 23.                         gen double cmean = .
 24.                         gen double clo   = .
 25.                         gen double chi   = .
 26.                         foreach c of local cats {
 27.                                 quietly count if `grouping' == `c'
 28.                                 if r(N) >= 2 {
 29.                                         quietly mean b_`outcome' if `group
> ing' == `c'
 30.                                         matrix mb = r(table)
 31.                                         quietly replace cmean = mb[1,1] if
>  `grouping' == `c'
 32.                                         quietly replace clo   = mb[5,1] if
>  `grouping' == `c'
 33.                                         quietly replace chi   = mb[6,1] if
>  `grouping' == `c'
 34.                                 }
 35.                         }
 36. 
.                         twoway ///
>                                 (scatter b_`outcome' `grouping' [aw=prec], //
> /
>                                         jitter(8) mcolor(navy%35) msymbol(O))
>  ///
>                                 (rcap clo chi `grouping', lcolor(black) lwidt
> h(medthick)) ///
>                                 (scatter cmean `grouping', mcolor(black) msym
> bol(D) msize(medlarge)), ///
>                                 yline(0, lpattern(dash) lcolor(gs8)) ///
>                                 ytitle("Per-scandal effect on `ytitle'") ///
>                                 xtitle("Type of official involved") ///
>                                 xlabel(`xlab', noticks labsize(small)) ///
