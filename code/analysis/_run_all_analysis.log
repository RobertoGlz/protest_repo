>                                 xlabel(-`window_length'(`bin_width')`window_l
> ength', nogrid labsize(medium)) ///
>                                 ylabel(, labsize(medlarge) format(%3.2fc)))
 53.                 graph export "${work}/results/figures/bjs_`outcome'_`windo
> w'_cxyfe.pdf", replace
 54.                 
.                 /* Store effect estimates in a matrix to aggregate in bins */
.                 local n_bins = 2*`window_length'/`bin_width'
 55.                 display in yellow "Number of `bin_width' day bins: `n_bins
> '"
 56.                 
.                 matrix agg_b = J(`n_bins', 1, .)
 57.                 matrix agg_se = J(`n_bins', 1, .)
 58.                 
.                 matrix ones = J(1, `bin_width', 1)
