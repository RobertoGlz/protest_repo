  5.                 generate lag_`bin_numb' = (window <= `bbb' & window >=  `b
> bb'-`bin_days')
  6.                 label variable lag_`bin_numb' "`bbb'"
  7.                 tabulate window lag_`bin_numb'
  8.         }
