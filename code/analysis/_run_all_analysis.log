. bysort id : generate post = (window >= 0)

. 
. /* add the outcomes of protests from the raw data */
. merge m:1 country date using `massmob', keep(1 3)
(variable country was str18, now str24 to accommodate using data's values)

    Result                      Number of obs
    -----------------------------------------
    Not matched                        40,526
        from master                    40,526  (_merge==1)
        from using                          0  (_merge==2)

    Matched                               444  (_merge==3)
    -----------------------------------------

. 
. /* observations only in master data are days around the scandal in which prot
> ests do not occurr so recode those values */
. recode num_peaceful_mm num_violent_mm num_gvt_violence_mm ///
>         indicator_peaceful_mm indicator_violent_mm indicator_gvt_violence_mm 
> ///
>         (missing = 0)
(40,526 changes made to num_peaceful_mm)
(40,526 changes made to num_violent_mm)
(40,526 changes made to num_gvt_violence_mm)
(40,526 changes made to indicator_peaceful_mm)
(40,526 changes made to indicator_violent_mm)
(40,526 changes made to indicator_gvt_violence_mm)

. 
. /* obtain month of date and day of date and year */
. generate month = month(date)

. generate day = dow(date)        

. generate year = year(date)

.         
. /* create variable for combination of Country-Year */
. egen country_year = group(country year) 

.         
. /* --------------------------------------------------------------------------
> --
>                                 Estimate event-study with Poisson QMLE 
> ---------------------------------------------------------------------------- 
> */
. /* Define local with outcomes of interest */
. local outcome_list = "num_peaceful_mm num_violent_mm num_gvt_violence_mm"

. 
. /* Define local for fixed effects to be absorbed */
. local fe_list = "month day country_year"

. 
. /* define tratment indicator */
. local treatvar = "post"

. 
. /* define level for confidence intervals */
. local ci_level = 90

. local alphaval = (100 - `ci_level')/100

. 
. /* define locals for storing days to pool in leads and lags */
. local bin_days = 30

. /* Check that event windows are divisible by the number of days to be pooled 
> */
. assert mod(`window_days', `bin_days') == 0

. /* Obtain number of bins that can be obtained with specified window lengths a
> nd bin days */
. local n_bins = `window_days'/`bin_days'

. display in yellow "Based on window length and number of days to be pooled we 
> can create `n_bins' `bin_days'-day bins"
Based on window length and number of days to be pooled we can create 4 30-day b
> ins

. 
. local bin_numb = 0 // counter for bin being created

. forvalues bbb = -`bin_days'(-`bin_days')-`window_days' {
  2.         /* add one to bin counter */
.         local ++bin_numb
  3.         /* create the indicator for the bin */
.         display in yellow "Creating bin for time-to-scandal in [`bbb',`=`bbb'
> +`bin_days'')"
  4.         generate lead_`bin_numb' = (window >= `bbb' & window <  `bbb'+`bin
> _days')
  5.         label variable lead_`bin_numb' "`bbb'"
  6.         tabulate window lead_`bin_numb'
  7. }
