> fc")
 50.                 }
 51.                 /* Effect for each event-time */
.                 eststo m_`outcome_counter' : did_imputation `outcome' `panelv
> ar' `timevar' `treat_cohort', ///
>                         fe(`fes') autosample cluster(group_cluster) delta(1) 
> ///
>                         `hzns' `pretrends' minn(0)
 52.                         
.                 event_plot, plottype(scatter) ciplottype(rspike) lag_opt(colo
> r(maroon)) lag_ci_opt(color(maroon%20)) ///
