. /* Program for combining panels from "https://raw.githubusercontent.com/steve
> ofconnell/PanelCombine/master/PanelCombine.do" */
. cap prog drop panelcombine

. prog define panelcombine
  1. qui {
  2. syntax, use(str asis) paneltitles(str asis) columncount(integer) save(str 
> asis) [CLEANup]
  3. preserve
  4. 
. tokenize `"`paneltitles'"'
  5. //read in loop
. local num 1
  6. while "``num''"~="" {
  7. local panel`num'title="``num''"
  8. local num=`num'+1
  9. }
 10. 
. 
. tokenize `use'
 11. //read in loop
. local num 1
 12. while "``num''"~="" {
 13. tempfile temp`num'
 14. insheet using "``num''", clear
 15. save `temp`num''
 16. local max = `num'
 17. local num=`num'+1
 18. }
 19. 
. //conditional processing loop
. local num 1
 20. while "``num''"~="" {
 21. local panellabel : word `num' of `c(ALPHA)'
 22. use `temp`num'', clear
 23.         if `num'==1 { //process first panel -- clip bottom
 24.         drop if strpos(v1,"Note:")>0 | strpos(v1,"in parentheses")>0 | str
> pos(v1,"p<0")>0
 25.         drop if v1=="\end{tabular}" | v1=="}"
 26.         replace v1 = "\midrule \multicolumn{`columncount'}{l}{ \linebreak 
> \textbf{\textit{Panel `panellabel': `panel1title'}}} \\" if v1=="\midrule" & 
> _n<8
 27.         replace v1 = "\midrule" if v1=="\bottomrule" & _n>4 //this is inte
> nded to replace the bottom double line; more robust condition probably exists
 28.         }
 29.         else if `num'==`max' { //process final panel -- clip top
 30.         //process header to drop everything until first hline
.         g temp = (v1 == "\midrule")
 31.         replace temp = temp+temp[_n-1] if _n>1
 32.         drop if temp==0
 33.         drop temp
 34.         
.         replace v1 = " \multicolumn{`columncount'}{l}{\linebreak \textbf{\tex
> tit{Panel `panellabel': `panel`num'title'}}} \\" if _n==1
 35.         }
 36.         else { //process middle panels -- clip top and bottom
 37.         //process header to drop everything until first hline
.         g temp = (v1 == "\midrule")
 38.         replace temp = temp+temp[_n-1] if _n>1
 39.         drop if temp==0
 40.         drop temp
 41.         
.         replace v1 = " \multicolumn{`columncount'}{l}{\linebreak \textbf{\tex
> tit{Panel `panellabel': `panel`num'title'}}} \\" if _n==1
 42.         drop if strpos(v1,"Note:")>0 | strpos(v1,"in parentheses")>0 | str
> pos(v1,"p<0")>0
 43.         drop if v1=="\end{tabular}" | v1=="}"
 44.         replace v1 = "\bottomrule" if v1=="\bottomrule\bottomrule"
 45.         }
 46.         save `temp`num'', replace
 47. local num=`num'+1
 48. }
 49. 
. use `temp1',clear
 50. local num 2
 51. while "``num''"~="" {
 52. append using `temp`num''
 53. local num=`num'+1
 54. }
 55. 
. outsheet using `save', noname replace noquote
 56. 
. 
.         if "`cleanup'"!="" { //erasure loop
 57.         tokenize `use'
 58.         local num 1
 59.                 while "``num''"~="" {
 60.                 erase "``num''"
 61.                 local num=`num'+1
 62.                 }
 63.         }
 64. 
. restore
 65. }
 66. end

. 
. 
. /* Define global with list of outcomes */
. global outcome_list = "num_violent_MM num_peaceful_MM government_response_vio
> lent"

. 
. /* Define Cluster and FE --------------------------------------------------- 
> */
. global CY_fe "i.country_id#i.year"

. global fe2 "i.country_id i.year"

. global scandal_fe "i.id_group"

. 
. global cl_country_year = "cluster i.country_id#i.year"

. global cl_country_year_group = "cluster i.country_id#i.year#i.grupo_dias"

. global cl_country = "cluster i.country_id"

. global cl_country_year_window = "cluster i.country_id#i.year#i.window"

. 
. /* Define sample of years from which we want to use the data */
. local firstyear = 2008

. 
. /* Define confidence interval level wanted in coefficient plots */
. local ci_level = 90

. local alphaval = 0.1

. 
. /* Define minimum number of observations required to run regression */
. local min_obs = 50

. 
. /* Loop analysis over window of days around the event ---------------------- 
> */
. foreach numbdays in 90 120 {
  2.         local panelnum = 0
  3.         /* loop analysis over positions */
.         foreach pos in "president" "governor" "nonpresgov" /*"sc_judge_congre
> ssman" "other_judiciary" "others" */ {
  4.                 local ++panelnum
  5.                 /* Set Globals with all treatment leads and lags */
.                 global leads ""
  6.                 global leads1 ""
  7.                 global leads2 ""
  8.                 global leads3 ""
  9.         
.                 forvalues i = `numbdays'(-30)30{
 10.                         global leads "${leads} s_lead`i'"
 11.                         global leads1 "${leads1} s1_lead`i'"
 12.                         global leads2 "${leads2} s2_lead`i'"
 13.                         global leads3 "${leads3} s3_lead`i'"
 14.                 }
 15.         
.                 global lags ""
 16.                 global lags1 ""
 17.                 global lags2 ""
 18.                 global lags3 ""
 19.         
.                 forvalues i = 30(30)`numbdays' {
 20.                         global lags "${lags} s_lag`i'"
 21.                         global lags1 "${lags1} s1_lag`i'"
 22.                         global lags2 "${lags2} s2_lag`i'"
 23.                         global lags3 "${lags3} s3_lag`i'"
 24.                 }
 25.         
.                 /* read in dataset with scandal classifications */
.                 import delimited using "${datfin}/scandals_classified.csv", c
> lear varnames(1) bindquotes(strict)
 26.                 drop date
 27.                 
.                 /* Read in dataset */
.                 merge 1:m id country using "${datfin}/protests_scandals_30day
> s_v3", keep(3)
 28.                 drop if (country == "Venezuela")
 29.                 
.                 replace position = "nonpresgov" if (position != "president" &
>  position != "governor")
 30. 
.                 
.                 /* Create groups with days since/to event */
.                 egen grupo_dias = group(${lags} ${leads})
 31.                 egen group_cluster = group(country_id year grupo_dias)
 32.         
.                 /* Iterate over outcomes */
.                 estimates clear
 33.                 local y_counter = 0
 34.                 foreach outcome in ${outcome_list} {
 35.                         /* Message for knowing which outcome is being comp
> uted */
.                         display in yellow "Estimate IRR for `outcome' in scan
> dals for `pos'"
 36.                         /* Add one to outcome counter */
.                         local ++y_counter
 37.                         
.                         /* Count observations in subsample */
.                         count if year >= `firstyear' & position == "`pos'" & 
> !missing(`outcome')
 38.                         local nobs = r(N)
 39.                         
.                         /* summarize outcome */
.                         summarize `outcome' if year >= `firstyear' & position
>  == "`pos'" & !missing(`outcome')
 40.                         local outvariance = r(sd)^2
 41.                         
.                         /* Check if there are enough observations to run regr
> ession */
.                         if `nobs' < `min_obs' | `outvariance' == 0 {
 42.                                 display in red "Insufficient observations 
> (`nobs') for `outcome' with position `pos'. Skipping regression."
 43.                                 
.                         }
 44.                         else {
 45.                                 /* Estimate average coefficient */
.                                 eststo m_`y_counter'_`numbdays' : ppmlhdfe `o
> utcome' post ///
>                                         if year >= `firstyear' & position == 
> "`pos'", absorb(month day ${CY_fe}) vce(cluster group_cluster) irr
 46.                                 local av_est = string(exp(_b[post]), "%3.2
> fc")
 47.                                 local p_av_est = 2*normal(-abs(_b[post]/_s
> e[post]))
 48.                                 if `p_av_est' < 0.01 {
 49.                                         local p_string = "p < 0.01"
 50.                                 }
 51.                                 else {
 52.                                         local p_string = "p = " + string(`
> p_av_est', "%4.3fc")
 53.                                 }
 54.                                 quietly {
 55.                                         /* Estimate IRR (exp{b}) with pois
> son regression and export coefficient plot */
.                                         ppmlhdfe `outcome' ${leads} ${lags} /
> //
>                                                 if year >= `firstyear' & posi
> tion == "`pos'", absorb(month day ${CY_fe})  vce(cluster group_cluster) irr
 56.                                         /* Compute x-axis value in which v
> ertical line must be drawn */
.                                         local x_line_pos = (`numbdays'/30) + 
> 0.5
 57.                                         /* Get y-axis value of smallest CI
>  to show effect estimate text at that height */
.                                         local numcoefs = 2*(`numbdays'/30)
 58.                                         local y_eff_pos = 1
 59.                                         forvalues bbb = 1/`numcoefs' {
 60.                                                 local bound = r(table)[6, 
> `bbb']
 61.                                                 if `bound' > `y_eff_pos' &
>  `bound' != . { 
 62.                                                         local y_eff_pos = 
> `bound'
 63.                                                 }
 64.                                         }
 65.                                 }
 66.                                 /* Show coefficient plot */
.                                 coefplot, keep(${leads} ${lags}) eform(${lead
> s} ${lags}) ///
>                                         levels(`ci_level') baselevels omitted
>  vertical ///
>                                         xtitle("days since scandal", size(med
> ium)) xscale(titlegap(2)) ///
>                                         xline(`x_line_pos', lwidth(vthick) lp
> attern(solid) lcolor(black%10)) ///
>                                         ytitle("incidence rate ratio", size(m
> edium)) yscale(titlegap(2)) ///
>                                         yline(1, lwidth(medthin) lpattern(sho
> rtdash) lcolor(black)) ///
>                                         xlabel(, labsize(medium)) ylabel(#5, 
> nogrid format(%3.1fc) labsize(medium)) ///
>                                         ciopts(lcolor(black) lwidth(medthin))
>  mcolor(black) msize(medium) ///
>                                         legend(order(- "Avg. Effect = `av_est
> ' (`p_string')") pos(11) ring(0))
 67.                                 graph export ///
>                                 "${work}/results/figures/ppmlhdfe_es_`outcome
> '_`numbdays'window_since`firstyear'_overlaps_`ci_level'ci_`pos'.png", ///
>                                         replace
 68.                         }
 69.                 }
 70.                 /* Export table */
.                 esttab _all using Panel_`panelnum'.tex, replace b(3) se(3) bo
> oktabs ///
>                 star(* 0.1 ** 0.05 *** 0.01) nonotes ///
>                 stats(N, labels("Observations") fmt(0 0 3)) ///
>                 keep(post) varlabels(post "1(Post Scandal = 1)") ///
>                 mtitles("\shortstack{Violent \\ Protests}" "\shortstack{Non-v
> iolent \\ Protests}" "\shortstack{Gvt. Violent \\ Response}")
 71.         }
 72.         
.         panelcombine, use(Panel_1.tex Panel_2.tex Panel_3.tex /*Panel_4.tex P
> anel_5.tex*/) ///
>         columncount(3) paneltitles("President" "Governor" "Others" /*"SC Judg
> e - Congressman" "Other Judiciary" "Others"*/) ///
>         save("${work}/results/tables/ppmlhdfe_es_`numbdays'window_since`first
> year'_overlaps_`ci_level'ci_panels_byposition.tex") cleanup
 73. }
