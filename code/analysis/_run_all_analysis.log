> )+`kkk'..`bin_width'*(`kkk')+`kkk'-1]
 66.                                 matrix wts_t = wts'
 67.                                 matrix vcovs = e(V)[`bin_width'*(`kkk'-1)+
> `kkk'..`bin_width'*(`kkk')+`kkk'-1, `bin_width'*(`kkk'-1)+`kkk'..`bin_width'*
> (`kkk')+`kkk'-1]
 68.                         }
 69.                         else if `kkk' <= `=`n_bins'/2' & `kkk' != 1 {
 70.                                 matrix effs = e(b)[1, `bin_width'*(`kkk'-1
> )+(`kkk'-`=`kkk'-1')..`bin_width'*(`kkk')]
 71.                                 matrix effs_t = effs'
 72.                                 matrix wts = e(Nt)[1, `bin_width'*(`kkk'-1
> )+(`kkk'-`=`kkk'-1')..`bin_width'*(`kkk')]
 73.                                 matrix wts_t = wts'
 74.                                 matrix vcovs = e(V)[`bin_width'*(`kkk'-1)+
> (`kkk'-`=`kkk'-1')..`bin_width'*(`kkk'), `bin_width'*(`kkk'-1)+(`kkk'-`=`kkk'
