. global violent  "$output/Violent"

. global mid              "$violent/mid"

. global logs     "${path}/Logs"

. global graphs   "${output}/Graphs"

. global tables   "${output}/Tables"

. global overleaf "${identity}/Apps/Overleaf"

. local date: dis %td_NN_DD_CCYY date(c(current_date), "DMY")

. gl date_string = subinstr(trim("`date'"), " " , "_", .)

. /* ------------------------------------------------------------------------- 
> */
. 
. /* Define global with list of outcomes */
. global outcome_list = "num_violent_MM num_peaceful_MM government_response_vio
> lent"

. 
. /* Define inputs needed for the estimator */
. local idvars = "country id"

. local panelvar = "country_scandal_id"

. 
. local timevar = "date"

. local treat_cohort = "event_time"

. 
. local extra_fixedeff = "country year"

. 
. local se_cluster = "country_id year grupo_dias"

. 
. /* First year of data to use */
. local firstyear = 2008

. 
. /* Define confidence interval level wanted in coefficient plots */
. local ci_level = 90

. local alphaval = 0.1

. 
. /* Define number of days for window */
. local window_length = "120"

. local bin_width = "30"

. 
. /* Specify number of horizons and/or pretrends to be estimated */
. local hzns = "horizons(0/120)"

. local pretrends = "pretrends(120)"

. 
. /* Loop analysis over window of days around the event ---------------------- 
> */
. foreach numbdays in `window_length' {
  2.         /* Set Globals with all treatment leads and lags */
.         global leads ""
  3.         global leads1 ""
  4.         global leads2 ""
  5.         global leads3 ""
  6.         
.         forvalues i = `numbdays'(-`bin_width')`bin_width'{
  7.                 global leads "${leads} s_lead`i'"
  8.                 global leads1 "${leads1} s1_lead`i'"
  9.                 global leads2 "${leads2} s2_lead`i'"
 10.                 global leads3 "${leads3} s3_lead`i'"
 11.         }
 12.         
.         global lags ""
 13.         global lags1 ""
 14.         global lags2 ""
 15.         global lags3 ""
 16.         
.         forvalues i = `bin_width'(`bin_width')`numbdays' {
 17.                 global lags "${lags} s_lag`i'"
 18.                 global lags1 "${lags1} s1_lag`i'"
 19.                 global lags2 "${lags2} s2_lag`i'"
 20.                 global lags3 "${lags3} s3_lag`i'"
 21.         }
 22.         
.         /* Read in dataset */
.         use "${datfin}/protests_scandals_30days_v3", clear
 23.         drop if (country == "Venezuela")
 24.         
.         egen `panelvar' = group(`idvars')
 25.         
.         /* Create groups with days since/to event */
.         egen grupo_dias = group(${lags} ${leads})
 26.         egen group_cluster = group(`se_cluster')
 27.         
.         /* Iterate over outcomes and estimate treatment effects */
.         estimates clear
 28.         local outcome_counter = 0
 29.         foreach outcome in ${outcome_list} {
 30.                 /* Message for knowing outcome */
.                 display in yellow "Estimating treatment effects for `outcome'
> "
 31.                 
.                 /* Create event period variable */
.                 display in yellow "Creating event-time variable"
 32.                 capture drop `timevar'_aux
 33.                 generate `timevar'_aux = `timevar' if window == 0
 34.                 capture drop `treat_cohort'
 35.                 bysort `panelvar' : egen `treat_cohort' = min(`timevar'_au
> x)
 36.                 
.                 if "`extra_fixedeff'" != "" {
 37.                         capture drop auxvar
 38.                         egen auxvar = group(`extra_fixedeff')
 39.                         local fes = "auxvar"
 40.                 }
 41.                 
.                 /* Estimate */
.                 local ++outcome_counter
 42.                 /* Average effect across all event-time periods */
.                 did_imputation `outcome' `panelvar' `timevar' `treat_cohort',
>  ///
>                         fe(`fes') autosample cluster(group_cluster) delta(1) 
> minn(0)
 43.                 local av_est = string(e(b)[1,1], "%4.3fc")
 44.                 local p_av_est = 2*normal(-abs(e(b)[1,1]/sqrt(e(V)[1,1])))
 45.                 if `p_av_est' < 0.01 {
