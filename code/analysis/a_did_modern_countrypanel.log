. do a_did_modern_countrypanel.do 

. /* --------------------------------------------------------------------------
> --
>                                         Violent effects of apex corruption
> 
>         Code author: Roberto Gonzalez
>         Date: 2026-05-22
> 
>         Objective (Task 1, Design 1 -- "Country panel + non-scandal controls"
> ):
>                 Reproduce the Table 16 estimand with modern staggered-DiD
>                 estimators.  THE OBSERVATION IS A COUNTRY x 3-DAY BIN -- the 
> same
>                 3-day grouping used in the Latinobarometer modern-DiD code
>                 (all_estimators_no_dcdh_samesamp.do, time_bins = floor(./3)),
>  so
>                 the estimates are comparable across the two projects.
> 
>         Panel:
>                 Unit  = country (23 LAC).  Time = 3-day calendar bin.
>                 Treatment = country's FIRST scandal; treated from its first-s
> candal
>                         bin onward.  Never-treated cohort = the countries wit
> h no
>                         scandal in 2008+.
>                 Outcomes = mm_protests, mm_violent, mm_nonviolent, mm_gvr
>                         (3-day-bin sums).
>                 Event-study window = +-10 bins (+-30 days); bin -1 = referenc
> e.
> 
>         Estimators: OLS two-way FE, dCDH, BJS, SA.
> 
>         Outputs:
>                 ${tabout}/did_modern_cp_main.tex
>                 ${figout}/did_modern_cp_es_<outcome>.pdf
> ---------------------------------------------------------------------------- 
> */
. 
. if "`c(username)'" == "rob98" {
.         global identity "~/Dropbox"
. }

. global work   "${identity}/Corrupcion/Protest_Work"

. global path   "${identity}/Corrupcion/WORKING FOLDER/Event Study - Scandals"

. global datfin "${path}/Data/final"

. global tabout "${work}/results/tables"

. global figout "${work}/results/figures"

. 
. /* ============================================================
>    1.  LOAD DAILY PANEL, COLLAPSE TO COUNTRY x 3-DAY BIN
>    ============================================================ */
. use "${datfin}/panel_country_day.dta", clear

. keep if year >= 2008
(151,202 observations deleted)

. 
. quietly summarize date

. local d0 = r(min)

. gen long bin3 = floor((date - `d0')/3) + 1

. 
. collapse (sum) mm_protests mm_violent mm_nonviolent mm_gvr ///
>         (firstnm) country_id first_scandal_date, by(country bin3)

. 
. /* ============================================================
>    2.  TREATMENT TIMING
>    ============================================================ */
. gen long first_scandal_bin = floor((first_scandal_date - `d0')/3) + 1 ///
>         if !missing(first_scandal_date)
(8,952 missing values generated)

. 
. gen byte ever_treated   = !missing(first_scandal_bin)

. gen byte I_never_treated = (ever_treated == 0)

. gen byte D = ever_treated == 1 & bin3 >= first_scandal_bin

. label variable D "Post first-scandal"

. 
. gen long etime  = bin3 - first_scandal_bin if ever_treated == 1
(8,952 missing values generated)

. gen long cohort = first_scandal_bin
(8,952 missing values generated)

. replace cohort = 999999 if missing(cohort)
(8,952 real changes made)

. 
. xtset country_id bin3

Panel variable: country_id (strongly balanced)
 Time variable: bin3, 1 to 1492
         Delta: 1 unit

. 
. di as result "=== Country x 3-day-bin panel ==="
=== Country x 3-day-bin panel ===

. count
  34,316

. preserve

.         bysort country_id: keep if _n == 1
(34,293 observations deleted)

.         count
  23

.         di "Countries: " r(N)
Countries: 23

.         count if ever_treated == 1
  17

.         di "  treated:       " r(N)
  treated:       17

.         count if ever_treated == 0
  6

.         di "  never-treated: " r(N)
  never-treated: 6

. restore

. 
. /* ============================================================
>    3.  EVENT-STUDY DUMMIES (+-10 bins, omit bin -1 = reference)
>    Plot grid = 20 columns, event bins -10..-1,0..9.
>    Matrix column j  <->  event bin (j - 11):
>        col 1..10  = bins -10..-1   (col 10 = reference, left 0)
>        col 11..20 = bins 0..9
>    ============================================================ */
. forvalues k = 2/10 {
  2.         gen byte ev_l`k' = (etime == -`k') & ever_treated == 1
  3. }

. forvalues k = 0/9 {
  2.         gen byte ev_g`k' = (etime == `k') & ever_treated == 1
  3. }

. local es_dummies ev_l10 ev_l9 ev_l8 ev_l7 ev_l6 ev_l5 ev_l4 ev_l3 ev_l2 ///
>         ev_g0 ev_g1 ev_g2 ev_g3 ev_g4 ev_g5 ev_g6 ev_g7 ev_g8 ev_g9

. 
. local outcomes mm_protests mm_violent mm_nonviolent mm_gvr

. 
. /* ============================================================
>    4.  MAIN LOOP
>    ============================================================ */
. local oc = 0

. foreach y of local outcomes {
  2.         local ++oc
  3. 
.         if "`y'" == "mm_protests"   local ytitle "Number of protests"
  4.         if "`y'" == "mm_violent"    local ytitle "Number of violent protes
> ts"
  5.         if "`y'" == "mm_nonviolent" local ytitle "Number of non-violent pr
> otests"
  6.         if "`y'" == "mm_gvr"        local ytitle "Number of govt. violent 
> responses"
  7. 
.         matrix M_ols_b  = J(1,20,0)
  8.         matrix M_ols_se = J(1,20,0)
  9.         matrix M_dcdh_b  = J(1,20,0)
 10.         matrix M_dcdh_se = J(1,20,0)
 11.         matrix M_bjs_b  = J(1,20,0)
 12.         matrix M_bjs_se = J(1,20,0)
 13.         matrix M_sa_b  = J(1,20,0)
 14.         matrix M_sa_se = J(1,20,0)
 15. 
.         /* ---------- (1) OLS two-way FE ---------- */
.         di as result "--- OLS: `y' ---"
 16.         reghdfe `y' D, absorb(country_id bin3) cluster(country_id)
 17.         scalar b_ols_`oc'  = _b[D]
 18.         scalar se_ols_`oc' = _se[D]
 19.         scalar n_ols_`oc'  = e(N)
 20.         quietly reghdfe `y' `es_dummies', absorb(country_id bin3) cluster(
> country_id)
 21.         local cc = 0
 22.         foreach k of numlist 10 9 8 7 6 5 4 3 2 {
 23.                 local ++cc
 24.                 matrix M_ols_b[1,`cc']  = _b[ev_l`k']
 25.                 matrix M_ols_se[1,`cc'] = _se[ev_l`k']
 26.         }
 27.         forvalues k = 0/9 {
 28.                 matrix M_ols_b[1, 11+`k']  = _b[ev_g`k']
 29.                 matrix M_ols_se[1, 11+`k'] = _se[ev_g`k']
 30.         }
 31. 
.         /* ---------- (2) dCDH ---------- */
.         di as result "--- dCDH: `y' ---"
 32.         capture noisily did_multiplegt_dyn `y' country_id bin3 D, ///
>                 effects(10) placebo(10) cluster(country_id) graph_off
 33.         if _rc == 0 {
 34.                 scalar b_dcdh_`oc'  = e(Av_tot_effect)
 35.                 scalar se_dcdh_`oc' = e(se_avg_total_effect)
 36.                 forvalues k = 1/10 {
 37.                         capture matrix M_dcdh_b[1, 11-`k']  = e(Placebo_`k
> ')
 38.                         capture matrix M_dcdh_se[1, 11-`k'] = e(se_placebo
> _`k')
 39.                 }
 40.                 forvalues k = 1/10 {
 41.                         capture matrix M_dcdh_b[1, 10+`k']  = e(Effect_`k'
> )
 42.                         capture matrix M_dcdh_se[1, 10+`k'] = e(se_effect_
> `k')
 43.                 }
 44.         }
 45.         else {
 46.                 scalar b_dcdh_`oc' = .
 47.                 scalar se_dcdh_`oc' = .
 48.                 display in red "dCDH failed for `y'"
 49.         }
 50. 
.         /* ---------- (3) BJS (did_imputation) ---------- */
.         di as result "--- BJS: `y' ---"
 51.         capture noisily did_imputation `y' country_id bin3 first_scandal_b
> in, ///
>                 autosample minn(0) delta(1) cluster(country_id)
 52.         if _rc == 0 {
 53.                 scalar b_bjs_`oc'  = _b[tau]
 54.                 scalar se_bjs_`oc' = _se[tau]
 55.         }
 56.         else {
 57.                 scalar b_bjs_`oc' = .
 58.                 scalar se_bjs_`oc' = .
 59.                 display in red "BJS (static) failed for `y'"
 60.         }
 61.         capture noisily did_imputation `y' country_id bin3 first_scandal_b
> in, ///
>                 horizons(0/9) pretrends(10) autosample minn(0) delta(1) clust
> er(country_id)
 62.         if _rc == 0 {
 63.                 forvalues k = 2/10 {
 64.                         capture quietly lincom pre`k' - pre1
 65.                         if _rc == 0 {
 66.                                 matrix M_bjs_b[1, 11-`k']  = r(estimate)
 67.                                 matrix M_bjs_se[1, 11-`k'] = r(se)
 68.                         }
 69.                 }
 70.                 forvalues k = 0/9 {
 71.                         capture quietly lincom tau`k' - pre1
 72.                         if _rc == 0 {
 73.                                 matrix M_bjs_b[1, 11+`k']  = r(estimate)
 74.                                 matrix M_bjs_se[1, 11+`k'] = r(se)
 75.                         }
 76.                 }
 77.         }
 78.         else {
 79.                 display in red "BJS (event study) failed for `y'"
 80.         }
 81. 
.         /* ---------- (4) SA (eventstudyinteract) ---------- */
.         di as result "--- SA: `y' ---"
 82.         capture noisily eventstudyinteract `y' `es_dummies', ///
>                 cohort(cohort) control_cohort(I_never_treated) ///
>                 absorb(country_id bin3) vce(cluster country_id)
 83.         if _rc == 0 {
 84.                 matrix b_iw = e(b_iw)
 85.                 matrix V_iw = e(V_iw)
 86.                 local cc = 0
 87.                 foreach k of numlist 10 9 8 7 6 5 4 3 2 {
 88.                         local ++cc
 89.                         local j = colnumb(b_iw, "ev_l`k'")
 90.                         if `j' < . {
 91.                                 matrix M_sa_b[1,`cc']  = b_iw[1,`j']
 92.                                 matrix M_sa_se[1,`cc'] = sqrt(V_iw[`j',`j'
> ])
 93.                         }
 94.                 }
 95.                 forvalues k = 0/9 {
 96.                         local j = colnumb(b_iw, "ev_g`k'")
 97.                         if `j' < . {
 98.                                 matrix M_sa_b[1, 11+`k']  = b_iw[1,`j']
 99.                                 matrix M_sa_se[1, 11+`k'] = sqrt(V_iw[`j',
> `j'])
100.                         }
101.                 }
102.                 /* static = equally weighted avg of the 10 post bins */
.                 matrix wgt = J(1, colsof(b_iw), 0)
103.                 local npost = 0
104.                 forvalues k = 0/9 {
105.                         local j = colnumb(b_iw, "ev_g`k'")
106.                         if `j' < . {
107.                                 matrix wgt[1,`j'] = 1
108.                                 local ++npost
109.                         }
110.                 }
111.                 if `npost' > 0 {
112.                         matrix wgt = wgt / `npost'
113.                         matrix avg_b = wgt * b_iw'
114.                         matrix avg_V = wgt * V_iw * wgt'
115.                         scalar b_sa_`oc'  = avg_b[1,1]
116.                         scalar se_sa_`oc' = sqrt(avg_V[1,1])
117.                 }
118.         }
119.         else {
120.                 scalar b_sa_`oc' = .
121.                 scalar se_sa_`oc' = .
122.                 display in red "SA failed for `y'"
123.         }
124. 
.         /* ---------- combined event-study plot ---------- */
.         preserve
125.                 clear
126.                 set obs 20
127.                 gen bin = _n - 11          /* event bin: -10..9 */
128.                 foreach est in ols dcdh bjs sa {
129.                         gen double b_`est'  = .
130.                         gen double se_`est' = .
131.                         forvalues j = 1/20 {
132.                                 replace b_`est'  = M_`est'_b[1,`j']  in `j
> '
133.                                 replace se_`est' = M_`est'_se[1,`j'] in `j
> '
134.                         }
135.                         gen double ci_lo_`est' = b_`est' - 1.645*se_`est'
136.                         gen double ci_hi_`est' = b_`est' + 1.645*se_`est'
137.                 }
138.                 gen double bin_ols  = bin - 0.21
139.                 gen double bin_dcdh = bin - 0.07
140.                 gen double bin_bjs  = bin + 0.07
141.                 gen double bin_sa   = bin + 0.21
142. 
.                 twoway ///
>                         (rspike ci_lo_ols  ci_hi_ols  bin_ols,  lcolor(navy) 
>         lwidth(medium)) ///
>                         (scatter b_ols  bin_ols,  mcolor(navy)         msymbo
> l(O)  msize(small)) ///
>                         (rspike ci_lo_dcdh ci_hi_dcdh bin_dcdh, lcolor(cranbe
> rry)    lwidth(medium)) ///
>                         (scatter b_dcdh bin_dcdh, mcolor(cranberry)    msymbo
> l(T)  msize(small)) ///
>                         (rspike ci_lo_bjs  ci_hi_bjs  bin_bjs,  lcolor(forest
> _green) lwidth(medium)) ///
>                         (scatter b_bjs  bin_bjs,  mcolor(forest_green) msymbo
> l(D)  msize(small)) ///
>                         (rspike ci_lo_sa   ci_hi_sa   bin_sa,   lcolor(midblu
> e)      lwidth(medium)) ///
>                         (scatter b_sa   bin_sa,   mcolor(midblue)      msymbo
> l(Oh) msize(small)), ///
>                         yline(0, lcolor(red) lpattern(solid) lwidth(medthin))
>  ///
>                         xline(-0.5, lcolor(black%20) lpattern(solid) lwidth(v
> thick)) ///
>                         xtitle("Days since first scandal (3-day bins)", size(
> medium)) ///
>                         ytitle("`ytitle'", size(medium)) ///
>                         xlabel(-10 "-30" -8 "-24" -6 "-18" -4 "-12" -2 "-6" /
> //
>                                 0 "0" 2 "6" 4 "12" 6 "18" 8 "24", labsize(med
> small)) ///
>                         ylabel(, labsize(medsmall) format(%4.3fc)) ///
>                         legend(order(2 "OLS (TWFE)" 4 "dCDH" 6 "BJS" 8 "SA") 
> ///
>                                 rows(1) size(small) position(6) region(lcolor
> (none))) ///
>                         graphregion(color(white)) scheme(s2color)
143.                 graph export "${figout}/did_modern_cp_es_`y'.pdf", replace
144.         restore
145. }
