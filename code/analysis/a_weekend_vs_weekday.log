. do a_weekend_vs_weekday.do 

. /* --------------------------------------------------------------------------
> --
>                                         Violent effects of apex corruption
> 
>         Code author: Roberto Gonzalez
>         Date: 2026-05-20
> 
>         Objective (protests_plan.md, Task 4):
>                 Sample-split the headline OLS / Poisson C x Y FE specificatio
> ns by
>                 whether the scandal date falls on a weekend (Sat/Sun) or a we
> ekday
>                 (Mon-Fri).  Two motivations:
>                   (a) Weekend baselines are mechanically lower (less protest
>                       activity on weekend days), so a post-scandal jump can l
> ook
>                       bigger.  The heterogeneity check disciplines this.
>                   (b) Weekend scandals may be more "exogenously timed" relati
> ve to
>                       the news cycle (less strategic timing by political acto
> rs).
> 
>         Audit note:
>                 The plan asked to add i.dow to the main specs, but inspection
>  of
>                 ols_main.do and poisson_reg_main_countryxyear_fe.do shows day
> -of-week
>                 IS already in the spec (absorb(month day ...) in OLS;
>                 `i.month i.day` in Poisson).  The plan's note was stale.  So 
> this
>                 task focuses on the heterogeneity split only.
> 
>         Spec mirrored exactly from the headline scripts:
>                 OLS:  reghdfe outcome post, absorb(month day country#year)
>                          cluster(group_cluster)
>                 Poi:  poisson outcome post i.month i.day i.country_id#i.year,
>                          vce(cluster group_cluster) irr
>                 group_cluster = group(country_id year bin30), where bin30 is 
> the
>                 30-day window bin (matches PDF's "C x Y x DB" clustering).
> 
>         Outputs:
>                 - Tex tables (OLS + Poisson, wide +-120 + narrow +-30):
>                     ${work}/results/tables/wkd_vs_wkend_<estimator>_w<W>d.tex
>                 - Console log: panelled coefficient tables to read into the
>                   markdown results note.
> ---------------------------------------------------------------------------- 
> */
. 
. /* ------------------- Configuration for collaborators -------------------- *
> /
. if "`c(username)'" == "lalov" {
.         gl identity "C:\Users\lalov\ITAM Seira Research Dropbox\Eduardo River
> a"
. }

. if "`c(username)'" == "Rob_9" {
.         global identity "C:/Users/Rob_9/Dropbox"
. }

. if "`c(username)'" == "rob98" {
.         global identity "~/Dropbox"
. }

. 
. global work "${identity}/Corrupcion/Protest_Work"

. global path "${identity}/Corrupcion/WORKING FOLDER/Event Study - Scandals"

. global datfin "${path}/Data/final"

. global tabout "${work}/results/tables"

. 
. /* All 4 outcomes from the PDF main tables */
. global outcome_list "num_protests_MM num_violent_MM num_peaceful_MM governmen
> t_response_violent"

. 
. local firstyear = 2011

. 
. /* Loop over the two windows used in the PDF: wide (Table 1 et al.) and
>    narrow (Section 8, Tables 16-17) */
. foreach numbdays in 120 30 {
  2. 
.         display in yellow as result "========================================
> ========"
  3.         display in yellow as result " WINDOW = +-`numbdays' days"
  4.         display in yellow as result "=====================================
> ==========="
  5. 
.         use "${datfin}/protests_scandals_30days_v3", clear
  6.         drop if country == "Venezuela"
  7.         keep if abs(window) <= `numbdays'
  8.         keep if year >= `firstyear'
  9. 
.         /* Scandal date's day-of-week, then weekend flag */
.         gen byte _sdow = day if window == 0
 10.         bysort id (_sdow): replace _sdow = _sdow[1]
 11.         label var _sdow "Day-of-week of the scandal date (0=Sun..6=Sat)"
 12.         gen byte weekend_scandal = (inlist(_sdow, 0, 6))
 13.         label var weekend_scandal "Scandal date is Sat/Sun"
 14.         label define WKE 0 "Weekday scandal (Mon-Fri)" 1 "Weekend scandal 
> (Sat/Sun)", replace
 15.         label values weekend_scandal WKE
 16. 
.         /* Tab the scandal-level distribution */
.         preserve
 17.                 bysort id: keep if _n == 1
 18.                 display in yellow "=== one row per scandal: dow of scandal
>  ==="
 19.                 tab _sdow, missing
 20.                 display in yellow "=== one row per scandal: weekday vs wee
> kend ==="
 21.                 tab weekend_scandal, missing
 22.         restore
 23. 
.         /* 30-day window bin for clustering (matches C x Y x DB convention) *
> /
.         gen long bin30 = floor(window/30)
 24.         egen group_cluster = group(country_id year bin30)
 25. 
.         /* Estimate both estimators x {Full, Weekend, Weekday} x 4 outcomes *
> /
.         estimates clear
 26.         local oc = 0
 27.         foreach outcome in $outcome_list {
 28.                 local ++oc
 29. 
.                 /* ---- OLS ---- */
.                 eststo ols_full_`oc' : reghdfe `outcome' post, ///
>                         absorb(month day i.country_id#i.year) ///
>                         cluster(group_cluster)
 30.                 eststo ols_wend_`oc' : reghdfe `outcome' post if weekend_s
> candal == 1, ///
>                         absorb(month day i.country_id#i.year) ///
>                         cluster(group_cluster)
 31.                 eststo ols_wday_`oc' : reghdfe `outcome' post if weekend_s
> candal == 0, ///
>                         absorb(month day i.country_id#i.year) ///
>                         cluster(group_cluster)
 32. 
.                 /* ---- Poisson (IRR) ---- */
.                 capture eststo poi_full_`oc' : poisson `outcome' post i.month
>  i.day i.country_id#i.year, ///
>                         vce(cluster group_cluster) irr
 33.                 capture eststo poi_wend_`oc' : poisson `outcome' post i.mo
> nth i.day i.country_id#i.year ///
>                         if weekend_scandal == 1, vce(cluster group_cluster) i
> rr
 34.                 capture eststo poi_wday_`oc' : poisson `outcome' post i.mo
> nth i.day i.country_id#i.year ///
>                         if weekend_scandal == 0, vce(cluster group_cluster) i
> rr
 35.         }
 36. 
.         /* ------------------ Export LaTeX tables ------------------ */
.         /* Build the model list per panel from successfully-stored estimates
>            (some cells -- gvt response on the 25-scandal weekend subsample --
>            may fail to converge; capture eststo absorbs the error but esttab
>            then errors if you reference a missing estimate name).
>            esttab is invoked only over the existing models, with mtitles
>            matched to that subset. */
.         /* Note: ~ instead of a literal space inside the Gvt. Violent title -
> -
>            esttab's mtitles() option tokenises by whitespace, so a space insi
> de
>            one mtitle splits it into two, leaving "Gvt." in the header and th
> e
>            remainder leaking into the next column.  Using LaTeX's `~` keeps
>            esttab from breaking the title and LaTeX renders it as a space. */
.         local mt_protests  `"\shortstack{Protests}"'
 37.         local mt_violent   `"\shortstack{Violent\\Protests}"'
 38.         local mt_peaceful  `"\shortstack{Non-violent\\Protests}"'
 39.         local mt_gvr       `"\shortstack{Gvt.~Violent\\Response}"'
 40. 
.         foreach est in ols poi {
 41.                 foreach sam in full wend wday {
 42.                         local mlist
 43.                         local mttls
 44.                         foreach oc of numlist 1/4 {
 45.                                 capture estimates restore `est'_`sam'_`oc'
 46.                                 if _rc == 0 {
 47.                                         local mlist `mlist' `est'_`sam'_`o
> c'
 48.                                         if `oc' == 1 local mttls `mttls' `
> mt_protests'
 49.                                         if `oc' == 2 local mttls `mttls' `
> mt_violent'
 50.                                         if `oc' == 3 local mttls `mttls' `
> mt_peaceful'
 51.                                         if `oc' == 4 local mttls `mttls' `
> mt_gvr'
 52.                                 }
 53.                                 else display in red "skip: `est'_`sam'_`oc
> ' (no estimate)"
 54.                         }
 55.                         if "`mlist'" == "" {
 56.                                 display in red "no estimates for `est' / `
> sam' / w`numbdays'd"
 57.                                 continue
 58.                         }
 59.                         if "`est'" == "ols" {
 60.                                 esttab `mlist' ///
>                                         using "${tabout}/wkd_vs_wkend_`est'_w
> `numbdays'd_`sam'.tex", ///
>                                         replace b(3) se(3) booktabs star(* 0.
> 1 ** 0.05 *** 0.01) ///
>                                         stats(N r2, labels("Observations" "R-
> squared") fmt(0 3)) ///
>                                         keep(post) varlabels(post "Post Scand
> al") nonotes nonumber ///
>                                         mtitles(`mttls')
 61.                         }
 62.                         else {
 63.                                 esttab `mlist' ///
>                                         using "${tabout}/wkd_vs_wkend_`est'_w
> `numbdays'd_`sam'.tex", ///
>                                         replace b(3) se(3) booktabs star(* 0.
> 1 ** 0.05 *** 0.01) eform ///
>                                         stats(N, labels("Observations") fmt(0
> )) ///
>                                         keep(post) varlabels(post "Post Scand
> al (IRR)") nonotes nonumber ///
>                                         mtitles(`mttls')
 64.                         }
 65.                 }
 66.         }
 67. 
.         /* ------------------ Print to log for the markdown note ------------
> ------ */
.         display in yellow as result "=== OLS coefficients on Post (w`numbdays
> 'd) ==="
 68.         display in yellow "outcome  | sample   | b          | se         |
>  N"
 69.         foreach oc of numlist 1/4 {
 70.                 local outcome : word `oc' of $outcome_list
 71.                 foreach sam in full wend wday {
 72.                         capture estimates restore ols_`sam'_`oc'
 73.                         if _rc == 0 {
 74.                                 local b  = string(_b[post], "%9.4f")
 75.                                 local se = string(_se[post], "%9.4f")
 76.                                 local N  = string(e(N), "%9.0fc")
 77.                                 display "`outcome'  `sam'  `b'  `se'  `N'"
 78.                         }
 79.                 }
 80.         }
 81. 
.         display in yellow as result "=== Poisson IRR on Post (w`numbdays'd) =
> =="
 82.         display in yellow "outcome  | sample   | b          | se         |
>  IRR        | N"
 83.         foreach oc of numlist 1/4 {
 84.                 local outcome : word `oc' of $outcome_list
 85.                 foreach sam in full wend wday {
 86.                         capture estimates restore poi_`sam'_`oc'
 87.                         if _rc == 0 {
 88.                                 local b   = string(_b[post], "%9.4f")
 89.                                 local se  = string(_se[post], "%9.4f")
 90.                                 local irr = string(exp(_b[post]), "%9.4f")
 91.                                 local N   = string(e(N), "%9.0fc")
 92.                                 display "`outcome'  `sam'  `b'  `se'  `irr
> '  `N'"
 93.                         }
 94.                 }
 95.         }
 96. }
