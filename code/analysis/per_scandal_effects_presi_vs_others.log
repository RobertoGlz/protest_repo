. do per_scandal_effects_presi_vs_others.do 

. /* --------------------------------------------------------------------------
> --
>                                                 Violent effects of apex corru
> ption
> 
>         Code author: Roberto Gonzalez
>         Date: 2026-05-22
> 
>         Objective:
>                 Per-scandal effect-size box / jitter plots (as in
>                 per_scandal_effects.do) with a BINARY classification of the
>                 official involved:  President  vs  Others  (Others pools the
>                 Supreme Court Judge/Secretary and Others categories).
> 
>                 SELF-CONTAINED: this file runs the per-scandal regressions it
> self
>                 (it does not depend on per_scandal_effects.do or its flat fil
> e).
> 
>         Method:
>                 For each scandal s, inside its narrow +-30-day country window
> ,
>                     reghdfe outcome post, absorb(month day) vce(robust)
>                 and store the Post coefficient.  Then plot the distribution o
> f
>                 those per-scandal coefficients by President vs Others.
> 
>         Outputs (in ${work}/results/figures/):
>                 per_scandal_box_<outcome>_w30_presi.pdf
>                 per_scandal_jitter_<outcome>_w30_presi.pdf
>                 per_scandal_effects_w30_presi.dta  (the per-scandal estimates
> )
> ---------------------------------------------------------------------------- 
> */
. 
. /* ------------------- Configuration for collaborators -------------------- *
> /
. if "`c(username)'" == "lalov" {
.         gl identity "C:/Users/lalov/ITAM Seira Research Dropbox/Eduardo River
> a"
. }

. if "`c(username)'" == "Rob_9" {
.         global identity "C:/Users/Rob_9/Dropbox"
. }

. if "`c(username)'" == "rob98" {
.         global identity "~/Dropbox"
. }

. 
. global work   "${identity}/Corrupcion/Protest_Work"

. global path   "${identity}/Corrupcion/WORKING FOLDER/Event Study - Scandals"

. global datfin "${path}/Data/final"

. global resout "${work}/results"

. global figout "${work}/results/figures"

. 
. /* Narrow window per the plan */
. local window_length = 30

. 
. /* Outcomes (mirrors the 4-outcome panels in Protests.pdf) */
. local outcome_list = "num_protests_MM num_violent_MM num_peaceful_MM governme
> nt_response_violent"

. local outcome_number : word count `outcome_list'

. 
. /* CI level for the jitter overlay */
. local ci_level = 95

. local zcrit = invnormal(1 - (100-`ci_level')/200)

. 
. /* ============================================================
>    READ AND PREPARE
>    ============================================================ */
. use "${datfin}/protests_scandals_30days_v3_with_lv_of_agent_involved.dta", cl
> ear

. drop if country == "Venezuela"
(3,374 observations deleted)

. 
. /* event-time variable in this dataset is `window`; restrict to +-30 days */
. keep if abs(window) <= `window_length'
(31,921 observations deleted)

. 
. /* Numeric per-scandal id (id is the str scandal identifier) */
. egen scandal_enc = group(id)

. egen scandal_tag = tag(id)

. 
. /* Scandal date = calendar date at window == 0 (carried to every row) */
. gen double _sd = date if window == 0
(10,562 missing values generated)

. bysort scandal_enc (_sd): replace _sd = _sd[1]
(10440 real changes made)

. format _sd %td

. 
. /* Defensive: drop scandals with no within-window post variation */
. bysort scandal_enc: egen _pm = mean(post)

. drop if _pm == 0 | _pm == 1
(0 observations deleted)

. drop _pm

. 
. /* month and day (= dow) already exist in the data; used as FE */
. 
. quietly levelsof scandal_enc, local(slevels)

. local n_scandals : word count `slevels'

. display in yellow "Per-scandal regressions: `n_scandals' scandals x `outcome_
> number' outcomes"
Per-scandal regressions: 176 scandals x 4 outcomes

. 
. /* One-row-per-scandal metadata (official_involved drives the classification)
>  */
. preserve

.         keep if scandal_tag == 1
(10,560 observations deleted)

.         keep scandal_enc id country official_involved _sd

.         rename _sd scandal_date

.         tempfile metadata

.         save `metadata'
file C:\Users\rob98\AppData\Local\Temp\ST_526c_000002.tmp saved as .dta
    format

. restore

. 
. /* ============================================================
>    PER-SCANDAL REGRESSIONS
>    ============================================================ */
. matrix define scandal_info = J(`n_scandals', 3*`outcome_number', .)

. 
. forvalues s = 1/`n_scandals' {
  2.         local oc = 0
  3.         foreach outcome of local outcome_list {
  4.                 local ++oc
  5.                 quietly count if !missing(`outcome') & scandal_enc == `s'
  6.                 local nobs = r(N)
  7.                 if `nobs' > 30 {
  8.                         capture reghdfe `outcome' post if scandal_enc == `
> s', ///
>                                 absorb(month day) vce(robust)
  9.                         if _rc == 0 & !missing(_b[post]) & _se[post] < . &
>  _se[post] > 0 {
 10.                                 matrix scandal_info[`s', 3*`oc'-2] = _b[po
> st]
 11.                                 matrix scandal_info[`s', 3*`oc'-1] = _se[p
> ost]
 12.                                 matrix scandal_info[`s', 3*`oc']   = `nobs
> '
 13.                         }
 14.                 }
 15.         }
 16. }

. 
. /* Convert matrix to dataset and merge metadata back in */
. clear

. svmat scandal_info
number of observations will be reset to 176
Press any key to continue, or Break to abort
Number of observations (_N) was 0, now 176.

. generate scandal_enc = _n

. merge 1:1 scandal_enc using `metadata', nogenerate

    Result                      Number of obs
    -----------------------------------------
    Not matched                             0
    Matched                               176  
    -----------------------------------------

. 
. local oc = 0

. foreach outcome of local outcome_list {
  2.         local ++oc
  3.         rename scandal_info`=3*`oc'-2' b_`outcome'
  4.         rename scandal_info`=3*`oc'-1' se_`outcome'
  5.         rename scandal_info`=3*`oc''   n_`outcome'
  6. }

. 
. /* ============================================================
>    MERGE IN position FROM scandals_classified.csv
>    ============================================================ */
. preserve

.         import delimited using "${datfin}/scandals_classified.csv", ///
>                 clear varnames(1) bindquotes(strict)
(encoding automatically selected: UTF-8)
(7 vars, 186 obs)

.         keep id country position

.         tempfile cls

.         save `cls'
file C:\Users\rob98\AppData\Local\Temp\ST_526c_000004.tmp saved as .dta
    format

. restore

. merge 1:1 id country using `cls', keep(1 3) nogenerate

    Result                      Number of obs
    -----------------------------------------
    Not matched                             4
        from master                         4  
        from using                          0  

    Matched                               172  
    -----------------------------------------

. 
. /* ============================================================
>    BINARY CLASSIFICATION:  President  vs  Others
>    President is defined from `position' (scandals_classified.csv), to be
>    consistent with per_scandal_effects_apex.do.  "Others" pools every
>    non-president position (governor, sc_judge_congressman,
>    other_judiciary, others).  The 4 scandals not in the CSV have no
>    `position' -> left unclassified, drop out of the plots.
>    ============================================================ */
. gen byte presi = .
(176 missing values generated)

. replace presi = 1 if position == "president"
(45 real changes made)

. replace presi = 2 if !missing(position) & position != "president"
(127 real changes made)

. label define PRESI 1 "President" 2 "Others", replace

. label values presi PRESI

. label variable presi "Type of official involved (President vs Others)"

. 
. order scandal_enc id country official_involved position presi scandal_date //
> /
>         b_* se_* n_*

. compress
  variable scandal_enc was float now int
  variable official_involved was float now byte
  variable n_num_protests_MM was float now byte
  variable n_num_violent_MM was float now byte
  variable n_num_peaceful_MM was float now byte
  variable n_government_response_violent was float now byte
  variable scandal_date was double now int
  variable country was str44 now str18
  (8,624 bytes saved)

. save "${resout}/per_scandal_effects_w`window_length'_presi.dta", replace
file
    ~/Dropbox/Corrupcion/Protest_Work/results/per_scandal_effects_w30_presi.d
    > ta saved

. 
. di as result "=== Scandals by President vs Others (one row per scandal) ==="
=== Scandals by President vs Others (one row per scandal) ===

. tab presi, missing

    Type of |
   official |
   involved |
 (President |
 vs Others) |      Freq.     Percent        Cum.
------------+-----------------------------------
  President |         45       25.57       25.57
     Others |        127       72.16       97.73
          . |          4        2.27      100.00
------------+-----------------------------------
      Total |        176      100.00

. 
. /* ============================================================
>    PLOTS BY PRESIDENT vs OTHERS
>    ============================================================ */
. foreach outcome of local outcome_list {
  2. 
.         if "`outcome'" == "num_protests_MM"             local ytitle "protest
> s (any)"
  3.         if "`outcome'" == "num_violent_MM"              local ytitle "viol
> ent protests"
  4.         if "`outcome'" == "num_peaceful_MM"             local ytitle "peac
> eful protests"
  5.         if "`outcome'" == "government_response_violent" local ytitle "gvt.
>  violent response"
  6. 
.         /* ---- distribution summary (printed to log) ---- */
.         display in yellow "=== Per-scandal `outcome': President vs Others ===
> "
  7.         tabstat b_`outcome', by(presi) ///
>                 statistics(n mean p50 sd min max) columns(statistics)
  8.         mean b_`outcome', over(presi)
  9. 
.         /* ---- (a) box plot ---- */
.         /* Build per-category median note for this outcome.
>            Each category becomes its own quoted string so graph box renders
>            one median per row in the figure note. */
.         quietly levelsof presi, local(__cats)
 10.         local med_note `""'
 11.         foreach c of local __cats {
 12.                 quietly summarize b_`outcome' if presi == `c', detail
 13.                 local __mstr = string(r(p50), "%5.3f")
 14.                 local __lbl : label PRESI `c'
 15.                 local med_note `"`med_note' "Median `__lbl': `__mstr'""'
 16.         }
 17. 
.         graph box b_`outcome', over(presi, label(labsize(large))) ///
>                 nooutsides ///
>                 ytitle("Per-scandal effect on `ytitle'", size(medlarge)) ///
>                 ylabel(, format(%4.2f) angle(0) labsize(large)) ///
>                 yline(0, lpattern(dash) lcolor(gs8)) ///
>                 note(`med_note', size(medlarge)) ///
>                 medtype(line) ///
>                 box(1, lcolor(black) lwidth(thick)) ///
>                 box(2, lcolor(black) lwidth(thick)) ///
>                 scheme(s2color) graphregion(color(white))
 18.         graph export ///
>                 "${figout}/per_scandal_box_`outcome'_w`window_length'_presi.p
> df", replace
 19. 
.         /* ---- (b) jittered scatter with category mean + 95% CI ---- */
.         preserve
 20.                 keep if !missing(b_`outcome') & !missing(presi)
 21.                 generate double prec = 1 / se_`outcome'^2
 22.                 quietly summarize prec
 23.                 replace prec = prec / r(max)
 24. 
.                 quietly levelsof presi, local(cats)
 25.                 gen double cmean = .
 26.                 gen double clo   = .
 27.                 gen double chi   = .
 28.                 foreach c of local cats {
 29.                         quietly count if presi == `c'
 30.                         if r(N) >= 2 {
 31.                                 quietly mean b_`outcome' if presi == `c'
 32.                                 matrix mb = r(table)
 33.                                 quietly replace cmean = mb[1,1] if presi =
> = `c'
 34.                                 quietly replace clo   = mb[5,1] if presi =
> = `c'
 35.                                 quietly replace chi   = mb[6,1] if presi =
> = `c'
 36.                         }
 37.                 }
 38. 
.                 twoway ///
>                         (scatter b_`outcome' presi [aw=prec], ///
>                                 jitter(8) mcolor(navy%35) msymbol(O)) ///
>                         (rcap clo chi presi, lcolor(black) lwidth(medthick)) 
> ///
>                         (scatter cmean presi, mcolor(black) msymbol(D) msize(
> medlarge)), ///
>                         yline(0, lpattern(dash) lcolor(gs8)) ///
>                         ytitle("Per-scandal effect on `ytitle'") ///
>                         xtitle("Type of official involved") ///
>                         xlabel(1 "President" 2 "Others", noticks) ///
>                         xscale(range(0.5 2.5)) ///
>                         ylabel(, format(%4.2f) angle(0)) ///
>                         legend(order(3 "Category mean" 2 "95% CI" 1 "Per-scan
> dal b") ///
>                                 pos(1) ring(0) region(lcolor(gs10)) size(smal
> l) cols(1)) ///
>                         note("Each point is one scandal; marker size proporti
> onal to 1/SE^2." ///
>                                 "Narrow +-`window_length'-day window.") ///
>                         scheme(s2color) graphregion(color(white))
 39.                 graph export ///
>                         "${figout}/per_scandal_jitter_`outcome'_w`window_leng
> th'_presi.pdf", replace
 40.         restore
 41. }
