    ev_lead4 |   .2890921   .4432272     0.65   0.521    -.6301049    1.208289
    ev_lead3 |   .0714356   .4201026     0.17   0.867    -.7998038    .9426749
    ev_lead2 |   .0893374   .4827229     0.19   0.855    -.9117687    1.090444
     ev_lag0 |   .0844443   .4577618     0.18   0.855    -.8648955    1.033784
     ev_lag1 |   .1243185   .4028943     0.31   0.761    -.7112332    .9598702
     ev_lag2 |  -.1646177   .1643497    -1.00   0.327    -.5054581    .1762227
     ev_lag3 |  -.1282836   .1812751    -0.71   0.487    -.5042251    .2476578
     ev_lag4 |  -.1986936   .1560924    -1.27   0.216    -.5224094    .1250222
