. /* Program for combining panels from "https://raw.githubusercontent.com/steve
> ofconnell/PanelCombine/master/PanelCombine.do" */
. cap prog drop panelcombine

. prog define panelcombine
  1. qui {
  2. syntax, use(str asis) paneltitles(str asis) columncount(integer) save(str 
> asis) [CLEANup]
  3. preserve
  4. 
. tokenize `"`paneltitles'"'
  5. //read in loop
. local num 1
  6. while "``num''"~="" {
  7. local panel`num'title="``num''"
  8. local num=`num'+1
  9. }
 10. 
. 
. tokenize `use'
 11. //read in loop
. local num 1
 12. while "``num''"~="" {
 13. tempfile temp`num'
 14. insheet using "``num''", clear
 15. save `temp`num''
 16. local max = `num'
 17. local num=`num'+1
 18. }
 19. 
. //conditional processing loop
. local num 1
 20. while "``num''"~="" {
 21. local panellabel : word `num' of `c(ALPHA)'
 22. use `temp`num'', clear
 23.         if `num'==1 { //process first panel -- clip bottom
 24.         drop if strpos(v1,"Note:")>0 | strpos(v1,"in parentheses")>0 | str
> pos(v1,"p<0")>0
 25.         drop if v1=="\end{tabular}" | v1=="}"
 26.         replace v1 = "\midrule \multicolumn{`columncount'}{l}{ \linebreak 
> \textbf{\textit{Panel `panellabel': `panel1title'}}} \\" if v1=="\midrule" & 
> _n<8
 27.         replace v1 = "\midrule" if v1=="\bottomrule" & _n>4 //this is inte
> nded to replace the bottom double line; more robust condition probably exists
 28.         }
 29.         else if `num'==`max' { //process final panel -- clip top
 30.         //process header to drop everything until first hline
.         g temp = (v1 == "\midrule")
 31.         replace temp = temp+temp[_n-1] if _n>1
 32.         drop if temp==0
 33.         drop temp
 34.         
.         replace v1 = " \multicolumn{`columncount'}{l}{\linebreak \textbf{\tex
> tit{Panel `panellabel': `panel`num'title'}}} \\" if _n==1
 35.         }
 36.         else { //process middle panels -- clip top and bottom
 37.         //process header to drop everything until first hline
.         g temp = (v1 == "\midrule")
 38.         replace temp = temp+temp[_n-1] if _n>1
 39.         drop if temp==0
 40.         drop temp
 41.         
.         replace v1 = " \multicolumn{`columncount'}{l}{\linebreak \textbf{\tex
> tit{Panel `panellabel': `panel`num'title'}}} \\" if _n==1
 42.         drop if strpos(v1,"Note:")>0 | strpos(v1,"in parentheses")>0 | str
> pos(v1,"p<0")>0
 43.         drop if v1=="\end{tabular}" | v1=="}"
 44.         replace v1 = "\bottomrule" if v1=="\bottomrule\bottomrule"
 45.         }
 46.         save `temp`num'', replace
 47. local num=`num'+1
 48. }
 49. 
. use `temp1',clear
 50. local num 2
 51. while "``num''"~="" {
 52. append using `temp`num''
 53. local num=`num'+1
 54. }
 55. 
. outsheet using `save', noname replace noquote
 56. 
. 
.         if "`cleanup'"!="" { //erasure loop
 57.         tokenize `use'
 58.         local num 1
 59.                 while "``num''"~="" {
 60.                 erase "``num''"
 61.                 local num=`num'+1
 62.                 }
 63.         }
 64. 
. restore
 65. }
 66. end

. 
