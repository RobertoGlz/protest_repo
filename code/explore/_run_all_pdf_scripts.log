>                 graphregion(fcolor(white) lcolor(white) lwidth(vvvthin) ifcol
> or(white) ilcolor(white)  ///
>                 ilwidth(vvvthin)) ciopts(lwidth(*1.5) lcolor(black)) mcolor(b
> lack) scheme(plotplain)
 14.                 graph export "${work}/results/figures/poissreg_es_`outcome
> '_`window_days'd_`cilevel'ci_`posvar'`rrr'.png", replace
